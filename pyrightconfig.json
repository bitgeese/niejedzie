{
  "include": ["pipeline"],
  "exclude": [
    "pipeline/.venv",
    "pipeline/__pycache__",
    "pipeline/.pytest_cache",
    "node_modules",
    "dist",
    ".wrangler",
    ".astro"
  ],
  "pythonVersion": "3.12",
  "extraPaths": ["pipeline"],
  "executionEnvironments": [
    {
      "root": "pipeline",
      "extraPaths": ["."]
    }
  ],
  "reportMissingImports": "none"
}
