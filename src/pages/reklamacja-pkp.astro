---
import Base from '../layouts/Base.astro';

const faqItems = [
  {
    question: "Ile czasu mam na złożenie reklamacji PKP Intercity?",
    answer: "Na złożenie reklamacji za opóźnienie pociągu krajowego masz 12 miesięcy od daty przejazdu. W przypadku połączeń międzynarodowych termin wynosi 3 miesiące. Warto jednak złożyć reklamację jak najszybciej — im więcej czasu minie, tym trudniej o kompletną dokumentację."
  },
  {
    question: "Ile wynosi odszkodowanie za opóźniony pociąg PKP?",
    answer: "25% ceny biletu jednorazowego przy opóźnieniu od 60 do 119 minut. 50% ceny biletu przy opóźnieniu 120 minut i więcej. Odszkodowanie nie zostanie wypłacone, jeśli wyliczona kwota jest niższa niż 16 zł (równowartość 4 EUR)."
  },
  {
    question: "Czy dostanę pieniądze czy bon na kolejny przejazd?",
    answer: "Domyślnie PKP Intercity wypłaca odszkodowanie w formie bonu (vouchera) na przejazd. Jeśli chcesz otrzymać pieniądze przelewem na konto, musisz to wyraźnie zaznaczyć w reklamacji i podać numer konta bankowego."
  },
  {
    question: "Jak długo PKP Intercity rozpatruje reklamację?",
    answer: "PKP Intercity ma 30 dni na rozpatrzenie reklamacji od dnia jej przyjęcia. Jeśli w tym terminie nie dostaniesz odpowiedzi, reklamację uznaje się za rozpatrzoną pozytywnie na Twoją korzyść."
  },
  {
    question: "Czy mogę złożyć reklamację PKP online?",
    answer: "Tak. PKP Intercity udostępnia formularz reklamacyjny online na stronie intercity.pl w zakładce Reklamacje i skargi. Możesz też wysłać reklamację mailem lub pocztą tradycyjną."
  },
  {
    question: "Co zrobić gdy PKP odrzuci reklamację?",
    answer: "Jeśli PKP Intercity odrzuci reklamację lub nie odpowie w terminie, możesz złożyć skargę do Prezesa Urzędu Transportu Kolejowego (UTK) lub wniosek o postępowanie polubowne do Rzecznika Praw Pasażera Kolei na stronie pasazer.gov.pl. Obie te drogi są bezpłatne."
  },
  {
    question: "Czy potrzebuję potwierdzenia opóźnienia od konduktora?",
    answer: "Nie jest to wymagane — PKP Intercity weryfikuje opóźnienia we własnym systemie. Jednak potwierdzenie od konduktora lub z kasy biletowej może przyspieszyć rozpatrzenie reklamacji. Możesz też użyć zrzutu ekranu z aplikacji lub strony pokazującej opóźnienie."
  },
  {
    question: "Które pociągi kwalifikują się do odszkodowania?",
    answer: "Odszkodowanie przysługuje pasażerom pociągów dalekobieżnych PKP Intercity: EIP (Express InterCity Premium / Pendolino), EIC (Express InterCity), IC (InterCity), TLK (Twoje Linie Kolejowe) oraz połączeń interREGIO i ŁKA Sprinter."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Reklamacja PKP Intercity za opóźnienie — kompletny poradnik 2026",
  "description": "Jak złożyć reklamację w PKP Intercity za opóźniony pociąg. Krok po kroku: formularz, adresy, terminy, kwoty odszkodowania i co zrobić gdy reklamacja zostanie odrzucona.",
  "author": {
    "@type": "Organization",
    "name": "niejedzie.pl",
    "url": "https://niejedzie.pl"
  },
  "publisher": {
    "@type": "Organization",
    "name": "niejedzie.pl",
    "url": "https://niejedzie.pl"
  },
  "datePublished": "2026-03-26",
  "dateModified": "2026-03-26",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://niejedzie.pl/reklamacja-pkp"
  }
};
---
<Base
  title="Reklamacja PKP Intercity za opóźnienie — poradnik krok po kroku (2026)"
  description="Jak złożyć reklamację w PKP Intercity za opóźniony pociąg. Formularz online, adresy, terminy, kwoty odszkodowania 25% i 50%, oraz co zrobić gdy PKP odrzuci reklamację."
>

  <!-- Schema.org FAQPage + Article -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <!-- Hero -->
  <section class="bg-surface-dark border-b border-border">
    <div class="max-w-4xl mx-auto px-4 pt-10 pb-12">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-brand-400 text-sm font-semibold uppercase tracking-wider mb-3">Poradnik 2026</p>
        <h1 class="text-2xl md:text-3xl font-bold text-white mb-3">
          Reklamacja PKP Intercity<br/>
          <span class="text-brand-400">za opóźnienie pociągu</span>
        </h1>
        <p class="text-ink-faint max-w-lg mx-auto">
          Kompletny poradnik: kiedy przysługuje odszkodowanie, jak złożyć reklamację krok po kroku, jakie dokumenty przygotować i co zrobić gdy PKP odrzuci Twoje zgłoszenie.
        </p>
      </div>
    </div>
  </section>

  <!-- Quick summary / key facts -->
  <section class="max-w-4xl mx-auto px-4 -mt-6 relative z-10 mb-10">
    <div class="max-w-2xl mx-auto">
      <div class="bg-surface-raised rounded-2xl border border-border shadow-sm p-5 md:p-6">
        <h2 class="text-sm font-semibold text-ink-faint uppercase tracking-wider mb-4">Najważniejsze fakty</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
          <div>
            <div class="text-xl font-bold text-brand-500">25%</div>
            <div class="text-xs text-ink-muted mt-1">zwrot za 60-119 min opóźnienia</div>
          </div>
          <div>
            <div class="text-xl font-bold text-brand-500">50%</div>
            <div class="text-xs text-ink-muted mt-1">zwrot za 120+ min opóźnienia</div>
          </div>
          <div>
            <div class="text-xl font-bold text-ink">30 dni</div>
            <div class="text-xs text-ink-muted mt-1">na odpowiedź od PKP</div>
          </div>
          <div>
            <div class="text-xl font-bold text-ink">12 mies.</div>
            <div class="text-xs text-ink-muted mt-1">termin na złożenie</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Table of contents -->
  <section class="max-w-4xl mx-auto px-4 mb-10">
    <div class="max-w-2xl mx-auto">
      <div class="bg-surface-sunken rounded-xl p-5">
        <h2 class="text-sm font-semibold text-ink-secondary mb-3">Spis treści</h2>
        <nav>
          <ol class="space-y-1.5 text-sm">
            <li><a href="#kiedy-przysługuje" class="text-brand-600 hover:text-brand-700 underline underline-offset-2">1. Kiedy przysługuje odszkodowanie?</a></li>
            <li><a href="#ile-dostaniesz" class="text-brand-600 hover:text-brand-700 underline underline-offset-2">2. Ile wynosi odszkodowanie?</a></li>
            <li><a href="#jakie-pociagi" class="text-brand-600 hover:text-brand-700 underline underline-offset-2">3. Które pociągi się kwalifikują?</a></li>
            <li><a href="#jak-zlozyc" class="text-brand-600 hover:text-brand-700 underline underline-offset-2">4. Jak złożyć reklamację — krok po kroku</a></li>
            <li><a href="#dokumenty" class="text-brand-600 hover:text-brand-700 underline underline-offset-2">5. Jakie dokumenty przygotować?</a></li>
            <li><a href="#jak-dlugo" class="text-brand-600 hover:text-brand-700 underline underline-offset-2">6. Jak długo trwa rozpatrzenie?</a></li>
            <li><a href="#forma-wyplaty" class="text-brand-600 hover:text-brand-700 underline underline-offset-2">7. Bon czy przelew — forma wypłaty</a></li>
            <li><a href="#odrzucona" class="text-brand-600 hover:text-brand-700 underline underline-offset-2">8. Co zrobić gdy PKP odrzuci reklamację?</a></li>
            <li><a href="#faq" class="text-brand-600 hover:text-brand-700 underline underline-offset-2">9. Najczęstsze pytania (FAQ)</a></li>
          </ol>
        </nav>
      </div>
    </div>
  </section>

  <!-- Main content -->
  <article class="max-w-4xl mx-auto px-4">
    <div class="max-w-2xl mx-auto space-y-12">

      <!-- 1. Kiedy przysługuje odszkodowanie -->
      <section id="kiedy-przysługuje">
        <h2 class="text-xl font-bold text-ink mb-4">1. Kiedy przysługuje odszkodowanie za opóźniony pociąg?</h2>
        <div class="space-y-3 text-sm text-ink-secondary leading-relaxed">
          <p>
            Zgodnie z <strong class="text-ink">Rozporządzeniem (UE) 2021/782</strong> (wcześniej Rozporządzenie (WE) nr 1371/2007) dotyczącym praw pasażerów w ruchu kolejowym, odszkodowanie przysługuje Ci gdy:
          </p>
          <ul class="space-y-2 pl-1">
            <li class="flex items-start gap-2">
              <span class="text-brand-500 mt-0.5">&#10003;</span>
              <span>Twój pociąg dalekobieżny PKP Intercity dotarł do stacji docelowej z <strong class="text-ink">opóźnieniem co najmniej 60 minut</strong></span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-500 mt-0.5">&#10003;</span>
              <span>Posiadasz ważny bilet na ten przejazd (jednorazowy, nie okresowy — dla biletów okresowych obowiązują inne zasady)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-500 mt-0.5">&#10003;</span>
              <span>Wyliczona kwota odszkodowania przekracza <strong class="text-ink">16 zł</strong> (równowartość 4 EUR — poniżej tej kwoty PKP nie wypłaca odszkodowania)</span>
            </li>
          </ul>
          <div class="bg-brand-50 border border-brand-200 rounded-lg p-4 mt-4">
            <p class="text-ink-secondary text-xs font-medium mb-1">Ważne</p>
            <p class="text-delay-warn text-xs">
              Odszkodowanie <strong>nie przysługuje</strong>, jeśli przewoźnik poinformował Cię o opóźnieniu przed zakupem biletu. Nie przysługuje też w przypadku siły wyższej (np. ekstremalnych warunków pogodowych), choć PKP musi udowodnić, że opóźnienie było poza jego kontrolą.
            </p>
          </div>
        </div>
      </section>

      <!-- 2. Ile wynosi odszkodowanie -->
      <section id="ile-dostaniesz">
        <h2 class="text-xl font-bold text-ink mb-4">2. Ile wynosi odszkodowanie?</h2>
        <div class="space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <div class="bg-surface-raised rounded-xl border border-border p-5 text-center">
              <div class="text-3xl font-bold text-brand-500 mb-1">25%</div>
              <div class="text-sm font-semibold text-ink-secondary mb-1">ceny biletu</div>
              <div class="text-xs text-ink-muted">Opóźnienie <strong>60 — 119 minut</strong></div>
            </div>
            <div class="bg-surface-raised rounded-xl border border-border p-5 text-center">
              <div class="text-3xl font-bold text-brand-500 mb-1">50%</div>
              <div class="text-sm font-semibold text-ink-secondary mb-1">ceny biletu</div>
              <div class="text-xs text-ink-muted">Opóźnienie <strong>120 minut i więcej</strong></div>
            </div>
          </div>

          <div class="text-sm text-ink-secondary leading-relaxed space-y-3">
            <p>
              Odszkodowanie liczone jest od <strong class="text-ink">ceny biletu jednorazowego</strong> za opóźniony odcinek podróży. Jeśli kupiłeś bilet na cały przejazd (np. Kraków — Gdańsk z przesiadką w Warszawie), odszkodowanie dotyczy wyłącznie odcinka, na którym doszło do opóźnienia.
            </p>
          </div>

          <div class="bg-surface-raised rounded-xl border border-border p-5">
            <h3 class="text-sm font-semibold text-ink-secondary mb-3">Przykłady</h3>
            <div class="space-y-3 text-sm text-ink-secondary">
              <div class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-surface-sunken text-ink-muted font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">1</span>
                <div>
                  <p>Bilet kosztował <strong class="text-ink">89 zł</strong>, opóźnienie wyniosło <strong class="text-ink">75 minut</strong></p>
                  <p class="text-ink-faint">89 zł &times; 25% = <strong class="text-brand-600">22,25 zł</strong> — przysługuje (powyżej 16 zł)</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-surface-sunken text-ink-muted font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">2</span>
                <div>
                  <p>Bilet kosztował <strong class="text-ink">149 zł</strong>, opóźnienie wyniosło <strong class="text-ink">2,5 godziny</strong></p>
                  <p class="text-ink-faint">149 zł &times; 50% = <strong class="text-brand-600">74,50 zł</strong> — przysługuje</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-surface-sunken text-ink-muted font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">3</span>
                <div>
                  <p>Bilet kosztował <strong class="text-ink">39 zł</strong>, opóźnienie wyniosło <strong class="text-ink">65 minut</strong></p>
                  <p class="text-ink-faint">39 zł &times; 25% = 9,75 zł — <strong class="text-red-600">nie przysługuje</strong> (poniżej 16 zł)</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- 3. Które pociągi się kwalifikują -->
      <section id="jakie-pociagi">
        <h2 class="text-xl font-bold text-ink mb-4">3. Które pociągi się kwalifikują?</h2>
        <div class="text-sm text-ink-secondary leading-relaxed space-y-3">
          <p>
            Prawo do odszkodowania za opóźnienie dotyczy <strong class="text-ink">pociągów dalekobieżnych</strong> obsługiwanych przez PKP Intercity:
          </p>
          <div class="bg-surface-raised rounded-xl border border-border overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-surface-sunken">
                  <th class="text-left p-3 font-semibold text-ink-secondary">Kategoria</th>
                  <th class="text-left p-3 font-semibold text-ink-secondary">Nazwa</th>
                  <th class="text-center p-3 font-semibold text-ink-secondary">Odszkodowanie</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-border">
                <tr>
                  <td class="p-3 font-medium text-ink">EIP</td>
                  <td class="p-3 text-ink-secondary">Express InterCity Premium (Pendolino)</td>
                  <td class="p-3 text-center"><span class="text-green-600 font-semibold">Tak</span></td>
                </tr>
                <tr>
                  <td class="p-3 font-medium text-ink">EIC</td>
                  <td class="p-3 text-ink-secondary">Express InterCity</td>
                  <td class="p-3 text-center"><span class="text-green-600 font-semibold">Tak</span></td>
                </tr>
                <tr>
                  <td class="p-3 font-medium text-ink">IC</td>
                  <td class="p-3 text-ink-secondary">InterCity</td>
                  <td class="p-3 text-center"><span class="text-green-600 font-semibold">Tak</span></td>
                </tr>
                <tr>
                  <td class="p-3 font-medium text-ink">TLK</td>
                  <td class="p-3 text-ink-secondary">Twoje Linie Kolejowe</td>
                  <td class="p-3 text-center"><span class="text-green-600 font-semibold">Tak</span></td>
                </tr>
                <tr>
                  <td class="p-3 font-medium text-ink">IR</td>
                  <td class="p-3 text-ink-secondary">interREGIO</td>
                  <td class="p-3 text-center"><span class="text-green-600 font-semibold">Tak</span></td>
                </tr>
                <tr>
                  <td class="p-3 font-medium text-ink border-t-2 border-border">Regionalne</td>
                  <td class="p-3 text-ink-secondary border-t-2 border-border">Koleje Mazowieckie, SKM, PolRegio itd.</td>
                  <td class="p-3 text-center border-t-2 border-border"><span class="text-ink-faint">Inne zasady*</span></td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-ink-faint">
            * Przewoźnicy regionalni mają własne regulaminy reklamacji. Szczegóły znajdziesz na stronach poszczególnych przewoźników.
          </p>
        </div>
      </section>

      <!-- 4. Jak złożyć reklamację krok po kroku -->
      <section id="jak-zlozyc">
        <h2 class="text-xl font-bold text-ink mb-4">4. Jak złożyć reklamację — krok po kroku</h2>

        <div class="space-y-4">
          <!-- Step 1 -->
          <div class="bg-surface-raised rounded-xl border border-border p-5">
            <div class="flex items-start gap-3">
              <span class="w-7 h-7 rounded-full bg-brand-500 text-white font-bold text-sm flex items-center justify-center shrink-0 mt-0.5">1</span>
              <div>
                <h3 class="text-sm font-semibold text-ink mb-2">Zbierz dokumenty</h3>
                <ul class="space-y-1.5 text-sm text-ink-secondary">
                  <li class="flex items-start gap-2">
                    <span class="text-ink-faint">&bull;</span>
                    <span>Bilet (wydruk, e-bilet lub numer biletu internetowego)</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-ink-faint">&bull;</span>
                    <span>Potwierdzenie opóźnienia (od konduktora, z kasy lub zrzut ekranu z aplikacji/strony)</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-ink-faint">&bull;</span>
                    <span>Numer konta bankowego (jeśli chcesz przelew zamiast bonu)</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="bg-surface-raised rounded-xl border border-border p-5">
            <div class="flex items-start gap-3">
              <span class="w-7 h-7 rounded-full bg-brand-500 text-white font-bold text-sm flex items-center justify-center shrink-0 mt-0.5">2</span>
              <div>
                <h3 class="text-sm font-semibold text-ink mb-2">Pobierz formularz lub złóż online</h3>
                <p class="text-sm text-ink-secondary mb-3">
                  Wybierz jedną z trzech metod złożenia reklamacji:
                </p>

                <div class="space-y-3">
                  <!-- Online -->
                  <div class="bg-surface-sunken rounded-lg p-4">
                    <div class="flex items-center gap-2 mb-2">
                      <span class="text-xs font-semibold text-brand-600 bg-brand-100 px-2 py-0.5 rounded">Najszybciej</span>
                      <h4 class="text-sm font-semibold text-ink-secondary">Online — formularz na intercity.pl</h4>
                    </div>
                    <p class="text-xs text-ink-muted mb-2">
                      Wejdź na stronę PKP Intercity &rarr; Dla pasażera &rarr; Obsługa klientów &rarr; Reklamacje i skargi &rarr; Zgłoś reklamację. Wypełnij formularz online, załącz skan biletu.
                    </p>
                    <a
                      href="https://www.intercity.pl/pl/site/dla-pasazera/obsluga-klientow/reklamacje-i-skargi/zglos-reklamacje.html"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1 text-xs text-brand-600 hover:text-brand-700 font-medium"
                    >
                      Otwórz formularz reklamacyjny &rarr;
                    </a>
                  </div>

                  <!-- Email / PDF -->
                  <div class="bg-surface-sunken rounded-lg p-4">
                    <h4 class="text-sm font-semibold text-ink-secondary mb-2">E-mail z formularzem PDF</h4>
                    <p class="text-xs text-ink-muted mb-2">
                      Pobierz formularz reklamacyjny PDF ze strony intercity.pl, wypełnij, podpisz i wyślij mailem wraz ze skanem biletu.
                    </p>
                    <div class="space-y-1">
                      <a
                        href="https://www.intercity.pl/pl/dokumenty/formularze/Formularz-reklamacyjny-03-04-2025.pdf"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1 text-xs text-brand-600 hover:text-brand-700 font-medium"
                      >
                        Pobierz formularz PDF &rarr;
                      </a>
                    </div>
                  </div>

                  <!-- Post -->
                  <div class="bg-surface-sunken rounded-lg p-4">
                    <h4 class="text-sm font-semibold text-ink-secondary mb-2">Poczta tradycyjna</h4>
                    <p class="text-xs text-ink-muted mb-2">
                      Wydrukuj i wypełnij formularz, dołącz kopię biletu i wyślij listem poleconym na adres:
                    </p>
                    <div class="bg-surface-raised rounded border border-border p-3 text-xs text-ink-secondary font-mono">
                      „PKP Intercity" S.A.<br/>
                      Aleje Jerozolimskie 142A<br/>
                      02-305 Warszawa<br/>
                      <span class="text-ink-faint">z dopiskiem: Reklamacja</span>
                    </div>
                  </div>

                  <!-- In person -->
                  <div class="bg-surface-sunken rounded-lg p-4">
                    <h4 class="text-sm font-semibold text-ink-secondary mb-2">Osobiście w kasie biletowej</h4>
                    <p class="text-xs text-ink-muted">
                      Możesz też złożyć reklamację w dowolnej kasie biletowej PKP Intercity. Weź ze sobą bilet i dokument tożsamości.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="bg-surface-raised rounded-xl border border-border p-5">
            <div class="flex items-start gap-3">
              <span class="w-7 h-7 rounded-full bg-brand-500 text-white font-bold text-sm flex items-center justify-center shrink-0 mt-0.5">3</span>
              <div>
                <h3 class="text-sm font-semibold text-ink mb-2">Wypełnij formularz — co wpisać</h3>
                <ul class="space-y-1.5 text-sm text-ink-secondary">
                  <li class="flex items-start gap-2">
                    <span class="text-ink-faint">&bull;</span>
                    <span><strong class="text-ink">Dane osobowe</strong> — imię, nazwisko, adres, e-mail, telefon</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-ink-faint">&bull;</span>
                    <span><strong class="text-ink">Numer i data przejazdu</strong> — numer pociągu (np. IC 5313), data podróży</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-ink-faint">&bull;</span>
                    <span><strong class="text-ink">Trasa</strong> — stacja odjazdu i stacja docelowa</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-ink-faint">&bull;</span>
                    <span><strong class="text-ink">Numer biletu</strong> — widoczny na bilecie lub e-bilecie</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-ink-faint">&bull;</span>
                    <span><strong class="text-ink">Opis opóźnienia</strong> — planowa godzina przyjazdu, faktyczna godzina przyjazdu, czas opóźnienia</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-ink-faint">&bull;</span>
                    <span><strong class="text-ink">Żądanie</strong> — podaj kwotę odszkodowania (25% lub 50% ceny biletu) i <strong>wyraźnie zaznacz, że chcesz wypłatę przelewem</strong>, jeśli nie chcesz bonu</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-ink-faint">&bull;</span>
                    <span><strong class="text-ink">Numer konta</strong> — pełny numer rachunku bankowego (IBAN) do przelewu</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Step 4 -->
          <div class="bg-surface-raised rounded-xl border border-border p-5">
            <div class="flex items-start gap-3">
              <span class="w-7 h-7 rounded-full bg-brand-500 text-white font-bold text-sm flex items-center justify-center shrink-0 mt-0.5">4</span>
              <div>
                <h3 class="text-sm font-semibold text-ink mb-2">Wyślij i czekaj na odpowiedź</h3>
                <p class="text-sm text-ink-secondary">
                  Po wysłaniu reklamacji PKP Intercity ma <strong class="text-ink">30 dni</strong> na odpowiedź. Możesz śledzić status reklamacji na stronie:
                </p>
                <a
                  href="https://www.intercity.pl/pl/site/dla-pasazera/obsluga-klientow/reklamacje-i-skargi/sprawdz-status-swojej-reklamacji.html"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 text-sm text-brand-600 hover:text-brand-700 font-medium mt-2"
                >
                  Sprawdź status reklamacji na intercity.pl &rarr;
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- 5. Jakie dokumenty przygotować -->
      <section id="dokumenty">
        <h2 class="text-xl font-bold text-ink mb-4">5. Jakie dokumenty przygotować?</h2>
        <div class="bg-surface-raised rounded-xl border border-border p-5">
          <div class="space-y-3">
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg bg-green-100 text-green-600 flex items-center justify-center shrink-0 text-sm">&#10003;</div>
              <div>
                <h3 class="text-sm font-semibold text-ink">Bilet (wymagany)</h3>
                <p class="text-xs text-ink-muted">Oryginał, kopia lub numer biletu internetowego. W przypadku e-biletu wystarczy podać numer transakcji.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg bg-green-100 text-green-600 flex items-center justify-center shrink-0 text-sm">&#10003;</div>
              <div>
                <h3 class="text-sm font-semibold text-ink">Potwierdzenie opóźnienia (zalecane)</h3>
                <p class="text-xs text-ink-muted">Poświadczenie od konduktora lub z kasy biletowej. Nie jest obowiązkowe — PKP weryfikuje opóźnienia w swoim systemie — ale przyspiesza proces.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center shrink-0 text-sm">+</div>
              <div>
                <h3 class="text-sm font-semibold text-ink">Dodatkowe dowody (opcjonalne)</h3>
                <p class="text-xs text-ink-muted">Zrzuty ekranu z aplikacji PKP IC lub stron pokazujących opóźnienie, zdjęcia tablic informacyjnych na stacji, rachunki za dodatkowe koszty (np. taksówka, nocleg) jeśli domagasz się ich zwrotu.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- 6. Jak długo trwa rozpatrzenie -->
      <section id="jak-dlugo">
        <h2 class="text-xl font-bold text-ink mb-4">6. Jak długo trwa rozpatrzenie reklamacji?</h2>
        <div class="space-y-3 text-sm text-ink-secondary leading-relaxed">
          <div class="bg-surface-raised rounded-xl border border-border p-5">
            <div class="flex items-center gap-4">
              <div class="text-center shrink-0">
                <div class="text-2xl font-bold text-ink">30</div>
                <div class="text-xs text-ink-faint">dni</div>
              </div>
              <div>
                <p>
                  PKP Intercity ma <strong class="text-ink">maksymalnie 30 dni</strong> od daty przyjęcia reklamacji na udzielenie odpowiedzi.
                </p>
                <p class="mt-1 text-xs text-ink-faint">
                  Jeśli w tym terminie nie otrzymasz odpowiedzi, reklamację uważa się za rozpatrzoną na Twoją korzyść.
                </p>
              </div>
            </div>
          </div>

          <p>
            W praktyce większość reklamacji za opóźnienia pociągów jest rozpatrywana w ciągu <strong class="text-ink">2-3 tygodni</strong>. Reklamacje złożone online zazwyczaj są obsługiwane szybciej niż te wysłane pocztą.
          </p>

          <div class="bg-surface-raised rounded-xl border border-border p-5">
            <h3 class="text-sm font-semibold text-ink-secondary mb-3">Terminy na złożenie reklamacji</h3>
            <div class="space-y-2">
              <div class="flex items-center justify-between text-sm">
                <span class="text-ink-secondary">Pociągi krajowe (EIP, EIC, IC, TLK, IR)</span>
                <span class="font-semibold text-ink">12 miesięcy</span>
              </div>
              <div class="border-t border-border"></div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-ink-secondary">Połączenia międzynarodowe</span>
                <span class="font-semibold text-ink">3 miesiące</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- 7. Forma wypłaty -->
      <section id="forma-wyplaty">
        <h2 class="text-xl font-bold text-ink mb-4">7. Bon czy przelew — jak otrzymasz odszkodowanie?</h2>
        <div class="space-y-3 text-sm text-ink-secondary leading-relaxed">
          <p>
            PKP Intercity oferuje dwie formy wypłaty odszkodowania:
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <div class="bg-surface-raised rounded-xl border border-border p-5">
              <h3 class="text-sm font-semibold text-ink-secondary mb-2">Bon / voucher</h3>
              <p class="text-xs text-ink-muted mb-2">
                Domyślna forma wypłaty. Bon na przejazd PKP Intercity, który możesz wykorzystać przy zakupie kolejnego biletu.
              </p>
              <span class="text-xs font-medium text-ink-faint bg-surface-sunken px-2 py-0.5 rounded">Domyślnie</span>
            </div>
            <div class="bg-surface-raised rounded-xl border border-brand-200 p-5 ring-1 ring-brand-100">
              <h3 class="text-sm font-semibold text-ink-secondary mb-2">Przelew bankowy</h3>
              <p class="text-xs text-ink-muted mb-2">
                Pieniądze na Twoje konto. Musisz <strong>wyraźnie</strong> zaznaczyć tę opcję w reklamacji i podać numer rachunku (IBAN).
              </p>
              <span class="text-xs font-medium text-brand-600 bg-brand-50 px-2 py-0.5 rounded">Trzeba zażądać</span>
            </div>
          </div>
          <div class="bg-brand-50 border border-brand-200 rounded-lg p-4">
            <p class="text-ink-secondary text-xs font-medium mb-1">Wskazówka</p>
            <p class="text-delay-warn text-xs">
              Jeśli chcesz pieniądze zamiast bonu, napisz w reklamacji: <em>„Proszę o wypłatę odszkodowania w formie przelewu bankowego na rachunek: [numer IBAN]"</em>. Bez tego PKP wyśle bon.
            </p>
          </div>
        </div>
      </section>

      <!-- 8. Co gdy PKP odrzuci reklamację -->
      <section id="odrzucona">
        <h2 class="text-xl font-bold text-ink mb-4">8. Co zrobić gdy PKP odrzuci Twoją reklamację?</h2>
        <div class="space-y-4 text-sm text-ink-secondary leading-relaxed">
          <p>
            Jeśli PKP Intercity odrzuci reklamację lub udzieli niesatysfakcjonującej odpowiedzi, masz dwie drogi odwoławcze — obie <strong class="text-ink">bezpłatne</strong>:
          </p>

          <!-- UTK -->
          <div class="bg-surface-raised rounded-xl border border-border p-5">
            <div class="flex items-start gap-3">
              <span class="w-7 h-7 rounded-full bg-red-100 text-red-600 font-bold text-sm flex items-center justify-center shrink-0 mt-0.5">A</span>
              <div>
                <h3 class="text-sm font-semibold text-ink mb-2">Skarga do Prezesa UTK</h3>
                <p class="text-sm text-ink-secondary mb-2">
                  <strong class="text-ink">Urząd Transportu Kolejowego</strong> (UTK) nadzoruje przewoźników i sprawdzi czy PKP postąpiło zgodnie z prawem.
                </p>
                <div class="bg-surface-sunken rounded-lg p-3 space-y-1 text-xs text-ink-secondary">
                  <p><strong class="text-ink-secondary">Adres:</strong> UTK, Aleje Jerozolimskie 134, 02-305 Warszawa</p>
                  <p><strong class="text-ink-secondary">Strona:</strong> <a href="https://utk.gov.pl/pl/pasazerowie/skargi-i-reklamacje" target="_blank" rel="noopener noreferrer" class="text-brand-600 hover:text-brand-700">utk.gov.pl</a></p>
                </div>
                <p class="text-xs text-ink-faint mt-2">
                  Do skargi dołącz: kopię reklamacji wysłanej do PKP, odpowiedź PKP (jeśli ją otrzymałeś), kopię biletu.
                </p>
              </div>
            </div>
          </div>

          <!-- Rzecznik -->
          <div class="bg-surface-raised rounded-xl border border-border p-5">
            <div class="flex items-start gap-3">
              <span class="w-7 h-7 rounded-full bg-blue-100 text-blue-600 font-bold text-sm flex items-center justify-center shrink-0 mt-0.5">B</span>
              <div>
                <h3 class="text-sm font-semibold text-ink mb-2">Rzecznik Praw Pasażera Kolei</h3>
                <p class="text-sm text-ink-secondary mb-2">
                  Rzecznik działa przy Prezesie UTK i prowadzi <strong class="text-ink">postępowanie polubowne</strong> między Tobą a przewoźnikiem. Bezpłatne i często skuteczniejsze niż formalna skarga.
                </p>
                <div class="bg-surface-sunken rounded-lg p-3 space-y-1 text-xs text-ink-secondary">
                  <p><strong class="text-ink-secondary">Formularz online:</strong> <a href="https://www.pasazer.gov.pl/formularz" target="_blank" rel="noopener noreferrer" class="text-brand-600 hover:text-brand-700">pasazer.gov.pl/formularz</a></p>
                  <p><strong class="text-ink-secondary">E-mail:</strong> <a href="mailto:rzecznik@utk.gov.pl" class="text-brand-600 hover:text-brand-700">rzecznik@utk.gov.pl</a></p>
                  <p><strong class="text-ink-secondary">Adres:</strong> Rzecznik Praw Pasażera Kolei, Aleje Jerozolimskie 134, 02-305 Warszawa</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-surface-sunken rounded-lg p-4">
            <h3 class="text-sm font-semibold text-ink-secondary mb-2">Schemat postępowania</h3>
            <div class="flex flex-col md:flex-row items-start md:items-center gap-2 text-xs text-ink-secondary">
              <div class="bg-surface-raised rounded border border-border px-3 py-2 text-center">
                <div class="font-semibold text-ink">1. Reklamacja do PKP</div>
                <div class="text-ink-faint">max. 30 dni</div>
              </div>
              <span class="text-ink-faint hidden md:block">&rarr;</span>
              <span class="text-ink-faint md:hidden">&darr;</span>
              <div class="bg-surface-raised rounded border border-border px-3 py-2 text-center">
                <div class="font-semibold text-ink">2. Odpowiedź PKP</div>
                <div class="text-ink-faint">pozytywna / negatywna</div>
              </div>
              <span class="text-ink-faint hidden md:block">&rarr;</span>
              <span class="text-ink-faint md:hidden">&darr;</span>
              <div class="bg-surface-raised rounded border border-brand-200 px-3 py-2 text-center">
                <div class="font-semibold text-delay-warn">3. Odwołanie</div>
                <div class="text-ink-faint">UTK / Rzecznik</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="bg-brand-50 border border-brand-200 rounded-2xl p-6 md:p-8 text-center">
        <h2 class="text-lg font-bold text-ink mb-2">Twój pociąg się spóźnia?</h2>
        <p class="text-sm text-ink-secondary mb-4 max-w-md mx-auto">
          Sprawdź aktualne opóźnienie na niejedzie.pl. Jeśli Twój pociąg ma ponad 60 minut opóźnienia, automatycznie sprawdzimy czy przysługuje Ci odszkodowanie i pomożemy złożyć reklamację.
        </p>
        <a href="/" class="inline-block px-8 py-3 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-xl transition-colors text-sm">
          Sprawdź opóźnienie pociągu
        </a>
        <p class="text-xs text-ink-faint mt-3">
          Dane z systemu PKP PLK &middot; Aktualizowane co 2 minuty
        </p>
      </section>

      <!-- FAQ -->
      <section id="faq">
        <h2 class="text-sm font-semibold text-ink-faint uppercase tracking-wider mb-6 text-center">Najczęstsze pytania</h2>
        <div class="space-y-3">
          {faqItems.map((item) => (
            <div class="bg-surface-raised rounded-xl border border-border p-5">
              <h3 class="text-sm font-semibold text-ink mb-2">{item.question}</h3>
              <p class="text-sm text-ink-muted">{item.answer}</p>
            </div>
          ))}
        </div>
      </section>

    </div>
  </article>

  <!-- Bottom CTA -->
  <section class="max-w-4xl mx-auto px-4 py-16 text-center">
    <h2 class="text-2xl font-bold text-ink mb-3">Nie daj się zaskoczyć opóźnieniem</h2>
    <p class="text-ink-muted mb-6 max-w-md mx-auto">
      Monitoruj swój pociąg w czasie rzeczywistym. Jeśli opóźnienie przekroczy 60 minut — podpowiemy co dalej.
    </p>
    <a href="/" class="inline-block px-8 py-3 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-xl transition-colors text-sm">
      Sprawdź przesiadkę
    </a>
  </section>

</Base>
