---
import Base from '../layouts/Base.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Jak sprawdzić opóźnienie pociągu IC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Najszybciej przez Portal Pasażera (portalpasazera.pl) — wpisz numer pociągu lub stację i zobaczysz aktualne opóźnienie w minutach. Możesz też skorzystać z aplikacji KOLEO lub aplikacji PKP Intercity."
      }
    },
    {
      "@type": "Question",
      "name": "Gdzie sprawdzić opóźnienia pociągów online?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Opóźnienia pociągów sprawdzisz online na: Portal Pasażera (portalpasazera.pl), w aplikacji KOLEO, w aplikacji PKP Intercity, na rozklad-pkp.pl oraz na niejedzie.pl — który dodatkowo monitoruje przesiadki."
      }
    },
    {
      "@type": "Question",
      "name": "Czy mogę dostać odszkodowanie za opóźniony pociąg?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tak. Przy opóźnieniu 60-119 minut przysługuje zwrot 25% ceny biletu, a przy opóźnieniu 120+ minut — 50% ceny biletu. Dotyczy pociągów dalekobieżnych (EIP, EIC, IC, TLK). Reklamację składasz u przewoźnika w ciągu 3 miesięcy."
      }
    },
    {
      "@type": "Question",
      "name": "Co zrobić gdy przez opóźnienie nie zdążę na przesiadkę?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Jeśli opóźnienie pierwszego pociągu spowodowało utratę przesiadki, masz prawo jechać następnym pociągiem tego samego przewoźnika bez dopłaty. Zgłoś sytuację konduktorowi lub w kasie biletowej na stacji przesiadkowej."
      }
    }
  ]
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Jak sprawdzić opóźnienie pociągu",
  "description": "Poradnik krok po kroku: jak sprawdzić aktualne opóźnienie pociągu PKP online — przez Portal Pasażera, KOLEO, aplikację PKP IC i niejedzie.pl.",
  "step": [
    {
      "@type": "HowToStep",
      "name": "Wejdź na Portal Pasażera lub otwórz aplikację KOLEO",
      "text": "Otwórz portalpasazera.pl w przeglądarce lub uruchom aplikację KOLEO na telefonie."
    },
    {
      "@type": "HowToStep",
      "name": "Wpisz numer pociągu lub nazwę stacji",
      "text": "W wyszukiwarce wpisz numer pociągu (np. IC 5313) lub nazwę stacji, z której odjeżdżasz."
    },
    {
      "@type": "HowToStep",
      "name": "Sprawdź aktualne opóźnienie",
      "text": "System pokaże planowy i rzeczywisty czas przyjazdu/odjazdu. Różnica to opóźnienie w minutach."
    }
  ]
};
---
<Base
  title="Jak sprawdzić opóźnienie pociągu — poradnik 2026"
  description="Jak sprawdzić opóźnienie pociągu PKP? Poradnik krok po kroku: Portal Pasażera, KOLEO, aplikacja PKP IC, niejedzie.pl. Sprawdź gdzie jest Twój pociąg i czy się spóźnia."
>

  <!-- Schema.org: FAQ + HowTo -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

  <!-- Hero -->
  <section class="bg-surface-dark border-b border-border">
    <div class="max-w-4xl mx-auto px-4 pt-10 pb-12">
      <div class="max-w-2xl mx-auto text-center">
        <h1 class="text-2xl md:text-3xl font-bold text-white mb-3">
          Jak sprawdzić <span class="text-brand-400">opóźnienie pociągu</span>?
        </h1>
        <p class="text-ink-faint">
          Kompletny poradnik — wszystkie sposoby na sprawdzenie czy Twój pociąg jedzie na czas. Portal Pasażera, KOLEO, aplikacja PKP IC i inne narzędzia.
        </p>
      </div>
    </div>
  </section>

  <!-- Table of contents -->
  <section class="max-w-4xl mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto">
      <div class="bg-surface-raised rounded-2xl border border-border p-5 md:p-6 shadow-sm">
        <h2 class="text-sm font-semibold text-ink-faint uppercase tracking-wider mb-4">Spis treści</h2>
        <nav>
          <ol class="space-y-2 text-sm">
            <li><a href="#portal-pasazera" class="text-brand-500 hover:text-brand-600 underline underline-offset-2">1. Portal Pasażera — najdokładniejsze dane</a></li>
            <li><a href="#koleo" class="text-brand-500 hover:text-brand-600 underline underline-offset-2">2. KOLEO — opóźnienia przy kupowaniu biletów</a></li>
            <li><a href="#aplikacja-pkp-ic" class="text-brand-500 hover:text-brand-600 underline underline-offset-2">3. Aplikacja PKP Intercity</a></li>
            <li><a href="#rozklad-pkp" class="text-brand-500 hover:text-brand-600 underline underline-offset-2">4. Rozkład-PKP.pl — wyszukiwarka połączeń</a></li>
            <li><a href="#niejedzie" class="text-brand-500 hover:text-brand-600 underline underline-offset-2">5. niejedzie.pl — monitoring przesiadek</a></li>
            <li><a href="#inne-zrodla" class="text-brand-500 hover:text-brand-600 underline underline-offset-2">6. Inne źródła (tablice, media społecznościowe)</a></li>
            <li><a href="#porownanie" class="text-brand-500 hover:text-brand-600 underline underline-offset-2">7. Porównanie narzędzi — które wybrać?</a></li>
            <li><a href="#co-robic" class="text-brand-500 hover:text-brand-600 underline underline-offset-2">8. Co zrobić gdy pociąg jest opóźniony?</a></li>
            <li><a href="#przesiadka" class="text-brand-500 hover:text-brand-600 underline underline-offset-2">9. Opóźnienie a przesiadka — jak nie stracić połączenia</a></li>
            <li><a href="#odszkodowanie" class="text-brand-500 hover:text-brand-600 underline underline-offset-2">10. Odszkodowanie za opóźnienie pociągu</a></li>
            <li><a href="#faq" class="text-brand-500 hover:text-brand-600 underline underline-offset-2">11. Najczęstsze pytania</a></li>
          </ol>
        </nav>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="max-w-4xl mx-auto px-4 pb-6">
    <div class="max-w-2xl mx-auto">
      <div class="bg-surface-raised rounded-2xl border border-border p-6 md:p-8 shadow-sm">
        <p class="text-sm text-ink-secondary leading-relaxed mb-4">
          Opóźnienia pociągów w Polsce to codzienność — średnio <strong class="text-ink">co czwarty pociąg PKP Intercity</strong> nie przyjeżdża na czas. Niezależnie czy jedziesz IC, EIC, TLK czy pociągiem regionalnym, warto wiedzieć jak szybko sprawdzić aktualne opóźnienie.
        </p>
        <p class="text-sm text-ink-secondary leading-relaxed">
          W tym poradniku opisujemy <strong class="text-ink">wszystkie sposoby na sprawdzenie opóźnień pociągów</strong> w Polsce — od oficjalnych narzędzi PKP, przez popularne aplikacje, po niezależne serwisy. Pokażemy też co robić, gdy Twój pociąg się spóźnia i jak nie stracić przesiadki.
        </p>
      </div>
    </div>
  </section>

  <!-- 1. Portal Pasażera -->
  <section id="portal-pasazera" class="bg-surface-raised border-y border-border">
    <div class="max-w-4xl mx-auto px-4 py-10">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-lg font-bold text-ink mb-1">1. Portal Pasażera — najdokładniejsze dane o opóźnieniach</h2>
        <p class="text-xs text-ink-faint mb-5">portalpasazera.pl &middot; Aplikacja mobilna (Android, iOS) &middot; Bezpłatny</p>

        <div class="space-y-4 text-sm text-ink-secondary">
          <p>
            <strong class="text-ink">Portal Pasażera</strong> to oficjalne narzędzie PKP Polskich Linii Kolejowych (PKP PLK) — zarządcy infrastruktury kolejowej w Polsce. To ten sam system, który zasila elektroniczne tablice informacyjne na dworcach. Dane pochodzą bezpośrednio od dyżurnych ruchu na stacjach, więc są <strong class="text-ink">najdokładniejsze ze wszystkich dostępnych źródeł</strong>.
          </p>

          <h3 class="text-base font-semibold text-ink pt-2">Jak sprawdzić opóźnienie na Portalu Pasażera — krok po kroku</h3>

          <ol class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-100 text-brand-600 font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">1</span>
              <span>Wejdź na <strong class="text-ink">portalpasazera.pl</strong> lub otwórz aplikację Portal Pasażera na telefonie</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-100 text-brand-600 font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">2</span>
              <span>Wpisz <strong class="text-ink">numer pociągu</strong> (np. IC 5313) lub <strong class="text-ink">nazwę stacji</strong> w wyszukiwarkę</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-100 text-brand-600 font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">3</span>
              <span>System pokaże <strong class="text-ink">planowy i rzeczywisty czas</strong> przyjazdu/odjazdu dla każdej stacji na trasie</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-100 text-brand-600 font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">4</span>
              <span>Kliknij <strong class="text-ink">"Pociągi na mapie"</strong> żeby zobaczyć lokalizację pociągu w czasie rzeczywistym</span>
            </li>
          </ol>

          <h3 class="text-base font-semibold text-ink pt-2">Co zobaczysz na Portalu Pasażera</h3>
          <ul class="space-y-1.5">
            <li class="flex items-start gap-2">
              <span class="text-brand-400 mt-0.5">&#10003;</span>
              <span>Aktualne opóźnienie w minutach dla każdej stacji na trasie</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-400 mt-0.5">&#10003;</span>
              <span>Numer peronu i toru (z którego odjeżdża/przyjeżdża pociąg)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-400 mt-0.5">&#10003;</span>
              <span>Lokalizację pociągu na mapie w czasie rzeczywistym</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-400 mt-0.5">&#10003;</span>
              <span>Komunikaty o utrudnieniach i zmianach w rozkładzie</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-400 mt-0.5">&#10003;</span>
              <span>Tablicę odjazdów/przyjazdów dla wybranej stacji</span>
            </li>
          </ul>

          <div class="bg-surface-sunken rounded-xl p-4 border border-border">
            <p class="text-xs text-ink-muted">
              <strong class="text-ink-secondary">Uwaga:</strong> Od maja 2023 r. Portal Pasażera zastąpił dawny serwis Infopasażer (infopasazer.intercity.pl). Wszystkie dane o ruchu pociągów dostępne są teraz w jednym miejscu — na portalpasazera.pl.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. KOLEO -->
  <section id="koleo" class="max-w-4xl mx-auto px-4 py-10">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-lg font-bold text-ink mb-1">2. KOLEO — opóźnienia widoczne przy kupowaniu biletów</h2>
      <p class="text-xs text-ink-faint mb-5">koleo.pl &middot; Aplikacja mobilna (Android, iOS) &middot; Bezpłatny (konto wymagane)</p>

      <div class="space-y-4 text-sm text-ink-secondary">
        <p>
          <strong class="text-ink">KOLEO</strong> to popularna aplikacja do kupowania biletów kolejowych, która <strong class="text-ink">przy okazji pokazuje aktualne opóźnienia</strong> pociągów. Dane pobiera z systemu PKP PLK (tego samego co Portal Pasażera), ale odświeża je co ok. 10 minut.
        </p>

        <h3 class="text-base font-semibold text-ink pt-2">Jak sprawdzić opóźnienie w KOLEO</h3>

        <ol class="space-y-3">
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-brand-100 text-brand-600 font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">1</span>
            <span>Otwórz aplikację <strong class="text-ink">KOLEO</strong> i zaloguj się na swoje konto</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-brand-100 text-brand-600 font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">2</span>
            <span>Wyszukaj połączenie podając stację odjazdu i przyjazdu</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-brand-100 text-brand-600 font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">3</span>
            <span>Przy każdym połączeniu zobaczysz <strong class="text-ink">informację o punktualności</strong> — zielony znaczek (na czas) lub czerwony z liczbą minut opóźnienia</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-brand-100 text-brand-600 font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">4</span>
            <span>Kliknij w szczegóły połączenia żeby zobaczyć opóźnienie na poszczególnych stacjach</span>
          </li>
        </ol>

        <div class="bg-surface-sunken rounded-xl p-4 border border-border">
          <p class="text-xs text-ink-muted">
            <strong class="text-ink-secondary">Ograniczenie:</strong> KOLEO pokazuje opóźnienia tylko tych przewoźników, którzy wyrazili na to zgodę. Nie zobaczysz opóźnień Kolei Dolnośląskich, SKM Warszawa i Kolei Mazowieckich. Dane odświeżane co ~10 minut — mogą być lekko nieaktualne.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Aplikacja PKP Intercity -->
  <section id="aplikacja-pkp-ic" class="bg-surface-raised border-y border-border">
    <div class="max-w-4xl mx-auto px-4 py-10">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-lg font-bold text-ink mb-1">3. Aplikacja PKP Intercity — opóźnienia pociągów IC, EIC, EIP, TLK</h2>
        <p class="text-xs text-ink-faint mb-5">intercity.pl &middot; Aplikacja mobilna (Android, iOS) &middot; Bezpłatny</p>

        <div class="space-y-4 text-sm text-ink-secondary">
          <p>
            Oficjalna <strong class="text-ink">aplikacja PKP Intercity</strong> pozwala sprawdzić opóźnienia pociągów dalekobieżnych — IC, EIC, EIP i TLK. Funkcja śledzenia trasy pokazuje w czasie rzeczywistym, na której stacji znajduje się Twój pociąg i ile ma opóźnienia.
          </p>

          <h3 class="text-base font-semibold text-ink pt-2">Jak sprawdzić opóźnienie pociągu IC w aplikacji</h3>

          <ol class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-100 text-brand-600 font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">1</span>
              <span>Pobierz aplikację <strong class="text-ink">PKP Intercity</strong> z Google Play lub App Store</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-100 text-brand-600 font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">2</span>
              <span>Wyszukaj swoje połączenie lub otwórz kupiony bilet</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-100 text-brand-600 font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">3</span>
              <span>Przejdź do <strong class="text-ink">szczegółów trasy</strong> — zobaczysz stacje zaznaczane na szaro w miarę przejazdu pociągu</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-100 text-brand-600 font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">4</span>
              <span>Opóźnienie wyświetlane jest <strong class="text-ink">przy każdej stacji</strong> — zarówno planowy jak i rzeczywisty czas przyjazdu</span>
            </li>
          </ol>

          <h3 class="text-base font-semibold text-ink pt-2">Co zobaczysz w aplikacji PKP IC</h3>
          <ul class="space-y-1.5">
            <li class="flex items-start gap-2">
              <span class="text-brand-400 mt-0.5">&#10003;</span>
              <span>Opóźnienie w minutach na każdej stacji</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-400 mt-0.5">&#10003;</span>
              <span>Informację o torze i peronie</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-400 mt-0.5">&#10003;</span>
              <span>Śledzenie trasy w czasie rzeczywistym</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-400 mt-0.5">&#10003;</span>
              <span>Powiadomienia o zmianach (jeśli masz kupiony bilet w aplikacji)</span>
            </li>
          </ul>

          <div class="bg-surface-sunken rounded-xl p-4 border border-border">
            <p class="text-xs text-ink-muted">
              <strong class="text-ink-secondary">Ograniczenie:</strong> Aplikacja PKP Intercity obsługuje tylko pociągi dalekobieżne (IC, EIC, EIP, TLK). Nie sprawdzisz tu opóźnień pociągów regionalnych Polregio, Kolei Mazowieckich, SKM czy Kolei Dolnośląskich.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Rozkład-PKP.pl -->
  <section id="rozklad-pkp" class="max-w-4xl mx-auto px-4 py-10">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-lg font-bold text-ink mb-1">4. Rozkład-PKP.pl — opóźnienia w wyszukiwarce połączeń</h2>
      <p class="text-xs text-ink-faint mb-5">rozklad-pkp.pl &middot; Przeglądarka &middot; Bezpłatny</p>

      <div class="space-y-4 text-sm text-ink-secondary">
        <p>
          <strong class="text-ink">Rozkład-PKP.pl</strong> to oficjalna wyszukiwarka połączeń kolejowych, która przy okazji wyświetla <strong class="text-ink">aktualne komunikaty o opóźnieniach i utrudnieniach</strong> (moduł HIM — Hindrances Information Module).
        </p>

        <h3 class="text-base font-semibold text-ink pt-2">Jak korzystać</h3>

        <ol class="space-y-3">
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-brand-100 text-brand-600 font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">1</span>
            <span>Wejdź na <strong class="text-ink">rozklad-pkp.pl</strong></span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-brand-100 text-brand-600 font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">2</span>
            <span>Wyszukaj połączenie wpisując stację odjazdu i przyjazdu</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-brand-100 text-brand-600 font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">3</span>
            <span>Przy wynikach zobaczysz <strong class="text-ink">ikony ostrzegawcze</strong> jeśli na trasie są utrudnienia</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-brand-100 text-brand-600 font-bold text-xs flex items-center justify-center shrink-0 mt-0.5">4</span>
            <span>Zakładka <strong class="text-ink">"Komunikaty"</strong> (rozklad-pkp.pl/pl/him) pokazuje zbiorcze informacje o utrudnieniach</span>
          </li>
        </ol>

        <div class="bg-surface-sunken rounded-xl p-4 border border-border">
          <p class="text-xs text-ink-muted">
            <strong class="text-ink-secondary">Warto wiedzieć:</strong> Rozkład-PKP.pl nie pokazuje opóźnień w minutach w czasie rzeczywistym jak Portal Pasażera. Znajdziesz tu raczej ogólne komunikaty o utrudnieniach, zamknięciach torów i zastępczej komunikacji autobusowej.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. niejedzie.pl -->
  <section id="niejedzie" class="bg-surface-raised border-y border-border">
    <div class="max-w-4xl mx-auto px-4 py-10">
