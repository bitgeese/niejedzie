---
import Base from '../layouts/Base.astro';
Astro.response.status = 404;
---
<Base title="404 — pociąg odjechał bez tej strony">

  <section class="max-w-4xl mx-auto px-4 py-20 md:py-32 text-center">
    <div class="max-w-md mx-auto">
      <!-- Big 404 -->
      <div class="text-8xl md:text-9xl font-bold text-ink-faint select-none mb-2">404</div>

      <h1 class="text-xl md:text-2xl font-bold text-ink mb-3">
        Pociąg odjechał bez tej strony
      </h1>
      <p class="text-ink-muted text-sm mb-8">
        Albo ta strona nigdy nie istniała, albo się spóźniła i została odwołana. Zupełnie jak TLK do Przemyśla w piątek wieczorem.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/"
          class="px-6 py-2.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-xl transition-colors text-sm"
        >
          Wróć na stronę główną
        </a>
        <a
          href="/opoznienia/dzisiaj"
          class="px-6 py-2.5 bg-surface-raised hover:bg-surface-sunken text-ink-secondary font-medium rounded-xl border border-border-strong transition-colors text-sm"
        >
          Sprawdź opóźnienia
        </a>
      </div>

      <p class="text-xs text-ink-faint mt-10">
        Jeśli uważasz, że to błąd — napisz na <a href="mailto:kontakt@niejedzie.pl" class="text-brand-500 hover:text-brand-600 underline underline-offset-2">kontakt@niejedzie.pl</a>
      </p>
    </div>
  </section>

</Base>
