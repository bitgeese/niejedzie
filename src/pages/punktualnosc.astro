---
export const prerender = false;

import Base from '../layouts/Base.astro';
import StatCard from '../components/StatCard.astro';
import { fetchMonthlyStats } from '../lib/fetch-data';

// --- Mock fallback data ---
const MOCK_MONTHLY_TREND = [
  { month: 'Kwi 25', punctuality: 78.4 }, { month: 'Maj 25', punctuality: 80.1 },
  { month: 'Cze 25', punctuality: 82.3 }, { month: 'Lip 25', punctuality: 83.7 },
  { month: 'Sie 25', punctuality: 81.2 }, { month: 'Wrz 25', punctuality: 79.5 },
  { month: 'Paź 25', punctuality: 76.8 }, { month: 'Lis 25', punctuality: 74.1 },
  { month: 'Gru 25', punctuality: 71.3 }, { month: 'Sty 26', punctuality: 68.2 },
  { month: 'Lut 26', punctuality: 70.5 }, { month: 'Mar 26', punctuality: 73.2 },
];
const MOCK_OPERATORS = [
  { carrier: 'SKM Trójmiasto', punctuality: 85 },
  { carrier: 'PolRegio', punctuality: 81 },
  { carrier: 'Koleje Mazowieckie', punctuality: 78 },
  { carrier: 'PKP Intercity', punctuality: 73 },
];
const MOCK_CATEGORIES = [
  { category: 'EIP', punctuality: 82 },
  { category: 'EIC', punctuality: 76 },
  { category: 'IC', punctuality: 71 },
  { category: 'TLK', punctuality: 68 },
];

// --- Fetch live data ---
const monthlyData = await fetchMonthlyStats();
const hasLiveMonthly = (monthlyData?.monthlyTrend?.length ?? 0) > 0;
const hasLiveOperators = (monthlyData?.byOperator?.length ?? 0) > 0;
const hasLiveCategories = (monthlyData?.byCategory?.length ?? 0) > 0;

// Month formatter: "2026-03" → "Mar 26"
const fmtMonth = (m: string) => {
  const [y, mo] = m.split('-');
  const names = ['Sty','Lut','Mar','Kwi','Maj','Cze','Lip','Sie','Wrz','Paź','Lis','Gru'];
  return names[parseInt(mo, 10) - 1] + ' ' + y.slice(2);
};

// Build chart data (live or mock)
const trendMonths = hasLiveMonthly
  ? monthlyData!.monthlyTrend.map(t => fmtMonth(t.month))
  : MOCK_MONTHLY_TREND.map(t => t.month);
const trendValues = hasLiveMonthly
  ? monthlyData!.monthlyTrend.map(t => t.punctuality)
  : MOCK_MONTHLY_TREND.map(t => t.punctuality);

const operatorNames = hasLiveOperators
  ? monthlyData!.byOperator.map(o => o.carrier)
  : MOCK_OPERATORS.map(o => o.carrier);
const operatorValues = hasLiveOperators
  ? monthlyData!.byOperator.map(o => o.punctuality)
  : MOCK_OPERATORS.map(o => o.punctuality);

const categoryNames = hasLiveCategories
  ? monthlyData!.byCategory.map(c => c.category)
  : MOCK_CATEGORIES.map(c => c.category);
const categoryValues = hasLiveCategories
  ? monthlyData!.byCategory.map(c => c.punctuality)
  : MOCK_CATEGORIES.map(c => c.punctuality);

// Gauge: average punctuality
const avgPunctuality = trendValues.length > 0
  ? Math.round(trendValues.reduce((a, b) => a + b, 0) / trendValues.length * 10) / 10
  : 73.2;

// Best operator / worst category for stat cards
const bestOperator = hasLiveOperators
  ? monthlyData!.byOperator.reduce((a, b) => a.punctuality > b.punctuality ? a : b)
  : { carrier: 'SKM Trójmiasto', punctuality: 85 };
const worstCategory = hasLiveCategories
  ? monthlyData!.byCategory.reduce((a, b) => a.punctuality < b.punctuality ? a : b)
  : { category: 'TLK', punctuality: 68 };

// Avg delay from operators
const avgDelay = hasLiveOperators
  ? (monthlyData!.byOperator.reduce((s, o) => s + o.avgDelay, 0) / monthlyData!.byOperator.length).toFixed(1).replace('.', ',') + ' min'
  : '6,7 min';

const usesLiveData = hasLiveMonthly || hasLiveOperators || hasLiveCategories;
