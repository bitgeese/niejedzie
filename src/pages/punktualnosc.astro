      <div class="md:col-span-2 grid grid-cols-2 gap-3">
        <StatCard value={avgPunctuality.toFixed(1).replace('.', ',') + '%'} label="Punktualność ogółem" color={avgPunctuality >= 80 ? 'safe' : avgPunctuality >= 60 ? 'warn' : 'danger'} />
        <StatCard value={avgDelay} label="Średnie opóźnienie" color="brand" />
        <StatCard value={bestOperator.punctuality + '%'} label="Najlepszy przewoźnik" color="safe">
          <p class="font-ticket text-[0.5625rem] text-ink-faint mt-1 tracking-wider uppercase">{bestOperator.carrier}</p>
        </StatCard>
        <StatCard value={worstCategory.punctuality + '%'} label="Najgorsza kategoria" color="danger">
