---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import StatCard from '../../components/StatCard.astro';
import TrainOperator from '../../components/TrainOperator.astro';
import { fetchTodayDelays, EMPTY_TODAY } from '../../lib/fetch-data';

const data = await fetchTodayDelays() ?? EMPTY_TODAY;
const hasData = data.stats.totalTrains > 0;

// Format helpers
const fmtNumber = (n: number) => n.toLocaleString('pl-PL');
const fmtDelay = (n: number) => n.toFixed(1).replace('.', ',') + ' min';
const fmtPct = (n: number) => n.toFixed(1).replace('.', ',') + '%';

// Timestamp
const now = new Date();
const updateTime = now.toLocaleDateString('pl-PL', { day: '2-digit', month: '2-digit', year: 'numeric' })
  + ', ' + now.toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' });
---
<Base
  title="Opóźnienia pociągów dzisiaj — na żywo"
  description="Opóźnienia pociągów PKP dzisiaj w czasie rzeczywistym. Sprawdź które pociągi się spóźniają, punktualność sieci i aktualne utrudnienia."
>
  <slot name="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Opóźnienia pociągów dzisiaj",
      "description": "Aktualne opóźnienia pociągów PKP w Polsce. Dane odświeżane co 2 minuty.",
      "url": "https://niejedzie.pl/opoznienia/dzisiaj",
      "isPartOf": { "@type": "WebSite", "name": "niejedzie.pl", "url": "https://niejedzie.pl" },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://niejedzie.pl" },
          { "@type": "ListItem", "position": 2, "name": "Opóźnienia", "item": "https://niejedzie.pl/opoznienia" },
          { "@type": "ListItem", "position": 3, "name": "Dzisiaj", "item": "https://niejedzie.pl/opoznienia/dzisiaj" }
        ]
      }
    })} />
  </slot>

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-5 pt-12 pb-6">
    <p class="section-label mb-4">// opóźnienia na żywo</p>
    <h1 class="text-[2rem] md:text-[2.75rem] font-extrabold text-ink leading-[1.08] tracking-tight mb-3">
      Opóźnienia pociągów<br/><span class="text-brand-500">dzisiaj</span>
    </h1>
    <p class="text-ink-muted text-[1.0625rem] max-w-lg leading-relaxed mb-2">
      Aktualne opóźnienia wszystkich pociągów w Polsce. Dane z PKP PLK odświeżane co 2 minuty.
    </p>
    <p class="font-ticket text-[0.625rem] text-ink-faint tracking-wider uppercase">
      Ostatnia aktualizacja: {updateTime} &middot; Źródło: PKP PLK Otwarte Dane Kolejowe
    </p>
  </section>

  <!-- Stats row -->
  <section class="max-w-5xl mx-auto px-5 py-6 fade-up">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 stagger">
      <StatCard value={hasData ? fmtNumber(data.stats.totalTrains) : '—'} label="Pociągów dzisiaj" color="default" />
      <StatCard value={hasData ? fmtPct(data.stats.punctuality) : '—'} label="Punktualność" color={data.stats.punctuality >= 80 ? 'safe' : data.stats.punctuality >= 60 ? 'warn' : 'danger'} />
      <StatCard value={hasData ? fmtDelay(data.stats.avgDelay) : '—'} label="Średnie opóźnienie" color="brand" />
      <StatCard value={hasData ? String(data.stats.cancelled) : '—'} label="Odwołanych" color="danger" />
    </div>
  </section>

  <!-- Area chart — delays over the day -->
  <section class="max-w-5xl mx-auto px-5 py-8 fade-up">
    <div class="bg-surface-raised rounded-2xl border border-border p-5 md:p-7">
      <div class="flex items-center justify-between mb-6">
        <div>
          <p class="section-label mb-1.5">// rozkład opóźnień</p>
          <h2 class="text-lg font-bold text-ink tracking-tight">Opóźnienia w ciągu dnia</h2>
        </div>
        <span class="font-ticket text-[0.625rem] text-ink-faint tracking-wider uppercase">Śr. opóźnienie (min)</span>
      </div>
      {hasData ? (
        <div id="delay-area-chart" style="min-height: 280px;"></div>
      ) : (
        <div class="bg-surface-sunken rounded-xl p-8 text-center">
          <p class="font-ticket text-ink-faint text-sm">// brak danych</p>
          <p class="text-ink-muted text-sm mt-2">Dane pojawią się wkrótce. System zbiera informacje o opóźnieniach.</p>
        </div>
      )}
    </div>
  </section>

  <!-- Two-column: bar chart + gauge -->
  <section class="max-w-5xl mx-auto px-5 py-8 fade-up">
    <div class="grid md:grid-cols-5 gap-5">
      <!-- Horizontal bar chart — most delayed trains -->
      <div class="md:col-span-3 bg-surface-raised rounded-2xl border border-border p-5 md:p-7">
        <p class="section-label mb-1.5">// ranking opóźnień</p>
        <h2 class="text-lg font-bold text-ink tracking-tight mb-6">Najbardziej opóźnione pociągi</h2>
        {hasData && data.topDelayed.length > 0 ? (
          <div id="delayed-trains-chart" style="min-height: 340px;"></div>
        ) : (
          <div class="bg-surface-sunken rounded-xl p-8 text-center">
            <p class="font-ticket text-ink-faint text-sm">// brak danych</p>
            <p class="text-ink-muted text-sm mt-2">Dane pojawią się wkrótce. System zbiera informacje o opóźnieniach.</p>
          </div>
        )}
      </div>

      <!-- Radial gauge — punctuality -->
      <div class="md:col-span-2 bg-surface-raised rounded-2xl border border-border p-5 md:p-7 flex flex-col items-center justify-center">
        <p class="section-label mb-1.5">// punktualność sieci</p>
        <h2 class="text-lg font-bold text-ink tracking-tight mb-4">Punktualność sieci</h2>
        {hasData ? (
          <div id="punctuality-gauge" style="min-height: 240px; width: 100%;"></div>
        ) : (
          <div class="bg-surface-sunken rounded-xl p-8 text-center">
            <p class="font-ticket text-ink-faint text-sm">// brak danych</p>
            <p class="text-ink-muted text-sm mt-2">Dane pojawią się wkrótce. System zbiera informacje o opóźnieniach.</p>
          </div>
        )}
        <p class="font-ticket text-[0.625rem] text-ink-faint tracking-wider text-center mt-2">
          &lt;60% — <span class="text-delay-danger">KRYTYCZNIE</span> &middot;
          60-80% — <span class="text-delay-warn">SŁABO</span> &middot;
          &gt;80% — <span class="text-delay-safe">OK</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Live feed -->
  <section class="max-w-5xl mx-auto px-5 py-8 fade-up">
    <p class="section-label mb-1.5">// ostatnie opóźnienia</p>
    <h2 class="text-lg font-bold text-ink tracking-tight mb-6">Na żywo</h2>
    {hasData && data.topDelayed.length > 0 ? (
      <div class="space-y-3 stagger">
        {data.topDelayed.map((train) => (
          <div class="ticket-card rounded-xl p-4 fade-up">
            <div class="flex flex-wrap items-center gap-3">
              <TrainOperator trainNumber={train.trainNumber} carrier={train.carrier} />
              <span class={`badge ${train.delay >= 30 ? 'badge-danger' : 'badge-warn'}`}>+{train.delay} min</span>
              {train.route && <span class="text-[0.8125rem] text-ink-muted">{train.route}</span>}
              {train.station && <span class="ml-auto font-ticket text-[0.6875rem] text-ink-faint">Ostatnia: {train.station}</span>}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="bg-surface-sunken rounded-xl p-8 text-center">
        <p class="font-ticket text-ink-faint text-sm">// brak danych</p>
        <p class="text-ink-muted text-sm mt-2">Dane pojawią się wkrótce. System zbiera informacje o opóźnieniach.</p>
      </div>
    )}
  </section>

  <!-- Disruptions -->
  <section class="max-w-5xl mx-auto px-5 py-8 fade-up">
    <p class="section-label mb-1.5">// utrudnienia</p>
    <h2 class="text-lg font-bold text-ink tracking-tight mb-6">Aktualne utrudnienia</h2>
    {data.disruptions.length > 0 ? (
      <div class="space-y-4">
        {data.disruptions.map((d: any) => (
          <div class="bg-surface-raised rounded-2xl border border-border p-5">
            <div class="flex items-start gap-3">
              <span class="badge badge-warn shrink-0 mt-0.5">UTRUDNIENIE</span>
              <div>
                {(d.startStation || d.endStation || d.route) && (
                  <p class="font-semibold text-[0.9375rem] text-ink mb-1">
                    {d.startStation && d.endStation ? `${d.startStation} — ${d.endStation}` : (d.route || '')}
                  </p>
                )}
                <p class="text-[0.8125rem] text-ink-muted leading-relaxed">{d.message}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="bg-surface-sunken rounded-xl p-8 text-center">
        <p class="font-ticket text-ink-faint text-sm">// brak utrudnień</p>
        <p class="text-ink-muted text-sm mt-2">Aktualnie brak zgłoszonych utrudnień w ruchu kolejowym.</p>
      </div>
    )}
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-5 py-16 text-center fade-up">
    <h2 class="text-[1.5rem] md:text-[1.75rem] font-extrabold text-ink mb-4 tracking-tight">
      Masz przesiadkę?
    </h2>
    <p class="text-ink-muted mb-6 max-w-md mx-auto">
      Monitoruj połączenie i dostaniesz alert jeśli opóźnienie zagrozi Twojej przesiadce.
    </p>
    <a href="/" class="btn-primary">Sprawdź przesiadkę</a>
  </section>

  <!-- SEO content -->
  <section class="border-t border-border bg-surface-raised">
    <div class="max-w-3xl mx-auto px-5 py-16">
      <h2 class="text-xl font-bold text-ink mb-4 tracking-tight">Opóźnienia pociągów dzisiaj &mdash; co warto wiedzieć</h2>
      <div class="text-[0.9375rem] text-ink-muted leading-relaxed space-y-4">
        <p>
          Codziennie po polskich torach kursuje ponad 6 000 pociągów pasażerskich. Średnia punktualność w sieci kolejowej wynosi ok. 73%, co oznacza, że mniej więcej co czwarty pociąg dociera z opóźnieniem. Największe opóźnienia dotyczą pociągów dalekobieżnych &mdash; IC i TLK &mdash; szczególnie w godzinach szczytu (7:00-9:00 i 15:00-17:00).
        </p>
        <p>
          Dane prezentowane na tej stronie pochodzą z systemu PKP PLK Otwarte Dane Kolejowe i są odświeżane co 2 minuty. Pokazujemy opóźnienia w czasie rzeczywistym dla wszystkich przewoźników: PKP Intercity, PolRegio, Koleje Mazowieckie, SKM i innych.
        </p>
        <p>
          Jeśli Twój pociąg ma opóźnienie przekraczające 60 minut, przysługuje Ci <a href="/odszkodowanie-za-opoznienie" class="text-brand-500 hover:text-brand-600 underline underline-offset-2">odszkodowanie od przewoźnika</a>. Sprawdź nasz <a href="/jak-sprawdzic-opoznienie" class="text-brand-500 hover:text-brand-600 underline underline-offset-2">poradnik sprawdzania opóźnień</a>.
        </p>
      </div>
    </div>
  </section>

</Base>

<!-- Pass SSR data to browser for charts -->
<script define:vars={{
  areaHours: data.hourlyDelays.map(h => h.hour),
  areaDelays: data.hourlyDelays.map(h => h.avgDelay),
  barLabels: data.topDelayed.map(t => t.trainNumber),
  barDelays: data.topDelayed.map(t => t.delay),
  gaugePunctuality: data.stats.punctuality,
  chartHasData: hasData,
}}>
  window.__dzisiajCharts = {
    areaHours, areaDelays,
    barLabels, barDelays,
    gaugePunctuality,
    chartHasData,
  };
</script>

<!-- Area chart: delays over hours -->
<script>
  import ApexCharts from 'apexcharts';

  const d = (window as any).__dzisiajCharts;
  if (d?.chartHasData && d.areaHours.length > 0 && document.querySelector('#delay-area-chart')) {
    const areaOptions: ApexCharts.ApexOptions = {
      chart: {
        type: 'area',
        height: 280,
        fontFamily: 'Outfit, system-ui, sans-serif',
        background: 'transparent',
        toolbar: { show: false },
        zoom: { enabled: false },
        animations: { enabled: true, easing: 'easeinout', speed: 600, animateGradually: { enabled: true, delay: 80 } },
      },
      series: [{ name: 'Śr. opóźnienie', data: d.areaDelays }],
      colors: ['#c2410c'],
      fill: {
        type: 'gradient',
        gradient: { shadeIntensity: 1, opacityFrom: 0.4, opacityTo: 0.05, stops: [0, 90, 100] },
      },
      stroke: { curve: 'smooth', width: 2.5, lineCap: 'round' },
      grid: {
        borderColor: '#e7e5e0',
        strokeDashArray: 4,
        padding: { left: 8, right: 8 },
        xaxis: { lines: { show: false } },
        yaxis: { lines: { show: true } },
      },
      xaxis: {
        categories: d.areaHours,
        labels: { style: { fontFamily: 'JetBrains Mono, monospace', fontSize: '10px', colors: '#a8a29e' } },
        axisBorder: { show: true, color: '#e7e5e0' },
        axisTicks: { show: false },
        crosshairs: { stroke: { color: '#c2410c', width: 1, dashArray: 4 } },
      },
      yaxis: {
        labels: {
          style: { fontFamily: 'JetBrains Mono, monospace', fontSize: '10px', colors: '#a8a29e' },
          formatter: (val: number) => val.toFixed(0) + ' min',
        },
      },
      tooltip: {
        theme: 'light',
        style: { fontFamily: 'JetBrains Mono, monospace', fontSize: '11px' },
        y: { formatter: (val: number) => val.toFixed(1) + ' min' },
        marker: { show: true },
      },
      dataLabels: { enabled: false },
      annotations: {
        xaxis: [
          { x: '07:00', x2: '09:00', fillColor: '#c2410c', opacity: 0.06, label: { text: 'Szczyt poranny', style: { fontFamily: 'JetBrains Mono, monospace', fontSize: '9px', color: '#a8a29e' } } },
          { x: '15:00', x2: '17:00', fillColor: '#c2410c', opacity: 0.06, label: { text: 'Szczyt popołudniowy', style: { fontFamily: 'JetBrains Mono, monospace', fontSize: '9px', color: '#a8a29e' } } },
        ],
      },
    };

    const areaChart = new ApexCharts(document.querySelector('#delay-area-chart'), areaOptions);
    areaChart.render();
  }
</script>

<!-- Horizontal bar chart: most delayed trains -->
<script>
  import ApexCharts from 'apexcharts';

  const d = (window as any).__dzisiajCharts;
  if (d?.chartHasData && d.barLabels.length > 0 && document.querySelector('#delayed-trains-chart')) {
    const barOptions: ApexCharts.ApexOptions = {
      chart: {
        type: 'bar',
        height: 340,
        fontFamily: 'Outfit, system-ui, sans-serif',
        background: 'transparent',
        toolbar: { show: false },
        animations: { enabled: true, easing: 'easeinout', speed: 600, animateGradually: { enabled: true, delay: 80 } },
      },
      plotOptions: {
        bar: { horizontal: true, borderRadius: 4, barHeight: '65%' },
      },
      series: [{ name: 'Opóźnienie', data: d.barDelays }],
      colors: ['#c2410c'],
      fill: { type: 'solid', opacity: 0.9 },
      stroke: { width: 0 },
      xaxis: {
        labels: {
          style: { fontFamily: 'JetBrains Mono, monospace', fontSize: '10px', colors: '#a8a29e' },
          formatter: (val: string) => val + ' min',
        },
        axisBorder: { show: true, color: '#e7e5e0' },
        axisTicks: { show: false },
      },
      yaxis: {
        labels: { style: { fontFamily: 'JetBrains Mono, monospace', fontSize: '11px', colors: '#1c1917' } },
      },
      grid: {
        borderColor: '#e7e5e0',
        strokeDashArray: 4,
        padding: { left: 8, right: 8 },
        xaxis: { lines: { show: true } },
        yaxis: { lines: { show: false } },
      },
      labels: d.barLabels,
      tooltip: {
        theme: 'light',
        style: { fontFamily: 'JetBrains Mono, monospace', fontSize: '11px' },
        y: { formatter: (val: number) => '+' + val + ' min' },
      },
      dataLabels: {
        enabled: true,
        formatter: (val: number) => '+' + val + ' min',
        style: { fontFamily: 'JetBrains Mono, monospace', fontSize: '10px', colors: ['#fff'] },
        offsetX: -4,
      },
      states: {
        hover: { filter: { type: 'darken', value: 0.05 } },
        active: { filter: { type: 'darken', value: 0.1 } },
      },
    };

    const barChart = new ApexCharts(document.querySelector('#delayed-trains-chart'), barOptions);
    barChart.render();
  }
</script>

<!-- Radial gauge: punctuality -->
<script>
  import ApexCharts from 'apexcharts';

  const d = (window as any).__dzisiajCharts;
  if (d?.chartHasData && document.querySelector('#punctuality-gauge')) {
    const punctuality = d.gaugePunctuality;
    const gaugeColor = punctuality >= 80 ? '#16a34a' : punctuality >= 60 ? '#d97706' : '#dc2626';

    const gaugeOptions: ApexCharts.ApexOptions = {
      chart: {
        type: 'radialBar',
        height: 240,
        fontFamily: 'Outfit, system-ui, sans-serif',
        background: 'transparent',
        animations: { enabled: true, easing: 'easeinout', speed: 600 },
      },
      series: [punctuality],
      colors: [gaugeColor],
      plotOptions: {
        radialBar: {
          startAngle: -135,
          endAngle: 135,
          hollow: { size: '65%', background: 'transparent' },
          track: { background: '#e7e5e0', strokeWidth: '100%', margin: 0 },
          dataLabels: {
            name: {
              show: true,
              fontSize: '11px',
              fontFamily: 'JetBrains Mono, monospace',
              color: '#a8a29e',
              offsetY: 20,
            },
            value: {
              show: true,
              fontSize: '28px',
              fontFamily: 'Outfit, system-ui, sans-serif',
              fontWeight: '800',
              color: '#1c1917',
              offsetY: -16,
              formatter: (val: number) => val.toFixed(1) + '%',
            },
          },
        },
      },
      labels: ['PUNKTUALNOŚĆ'],
      stroke: { lineCap: 'round' },
      states: {
        hover: { filter: { type: 'none' } },
        active: { filter: { type: 'none' } },
      },
    };

    const gaugeChart = new ApexCharts(document.querySelector('#punctuality-gauge'), gaugeOptions);
    gaugeChart.render();
  }
</script>
