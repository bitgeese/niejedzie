---
import Base from '../layouts/Base.astro';
---
<Base title="Monitor przesiadek PKP — dostaniesz alert jesli nie zdazysz">

  <!-- Hero: straight to the przesiadki form -->
  <section class="bg-white border-b border-stone-200">
    <div class="max-w-4xl mx-auto px-4 pt-12 pb-14">
      <div class="max-w-xl mx-auto text-center mb-8">
        <h1 class="text-3xl md:text-4xl font-bold text-stone-900 mb-3">
          Masz przesiadke?<br/>
          <span class="text-orange-500">Sprawdzimy czy zdazysz.</span>
        </h1>
        <p class="text-stone-500 text-lg">
          Monitorujemy Twoj pociag i wyslemy alert jesli opoznienie zagrozi polaczeniu.
        </p>
      </div>

      <!-- Przesiadki form — the main CTA -->
      <div class="max-w-lg mx-auto bg-stone-50 rounded-2xl border border-stone-200 p-6">
        <form class="space-y-4">
          <div>
            <label class="block text-xs font-medium text-stone-500 mb-1.5 uppercase tracking-wide">Pociag 1 — skad jedziesz</label>
            <div class="flex gap-2">
              <input
                type="text"
                placeholder="np. IC 5313"
                class="flex-1 px-3.5 py-2.5 bg-white border border-stone-300 rounded-lg text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-orange-500/30 focus:border-orange-500 transition-all text-sm"
              />
              <input
                type="text"
                placeholder="Stacja odjazdu"
                class="flex-1 px-3.5 py-2.5 bg-white border border-stone-300 rounded-lg text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-orange-500/30 focus:border-orange-500 transition-all text-sm"
              />
            </div>
          </div>

          <div class="flex items-center gap-3 px-1">
            <div class="flex-1 border-t border-dashed border-stone-300"></div>
            <span class="text-xs font-medium text-stone-400 uppercase tracking-wider">Przesiadka</span>
            <div class="flex-1 border-t border-dashed border-stone-300"></div>
          </div>

          <div>
            <label class="block text-xs font-medium text-stone-500 mb-1.5 uppercase tracking-wide">Pociag 2 — dokad jedziesz</label>
            <div class="flex gap-2">
              <input
                type="text"
                placeholder="np. EIC 1701"
                class="flex-1 px-3.5 py-2.5 bg-white border border-stone-300 rounded-lg text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-orange-500/30 focus:border-orange-500 transition-all text-sm"
              />
              <input
                type="text"
                placeholder="Stacja docelowa"
                class="flex-1 px-3.5 py-2.5 bg-white border border-stone-300 rounded-lg text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-orange-500/30 focus:border-orange-500 transition-all text-sm"
              />
            </div>
          </div>

          <button
            type="submit"
            class="w-full py-3 bg-orange-500 hover:bg-orange-600 text-white font-semibold rounded-xl transition-colors text-sm"
          >
            Sprawdz przesiadke
          </button>
        </form>

        <p class="text-center text-xs text-stone-400 mt-3">
          Dane z systemu PKP PLK &middot; Aktualizowane co minute
        </p>
      </div>
    </div>
  </section>

  <!-- How it works — leads to understanding the value -->
  <section class="max-w-4xl mx-auto px-4 py-14">
    <h2 class="text-center text-sm font-semibold text-stone-400 uppercase tracking-wider mb-10">Jak to dziala</h2>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="w-10 h-10 rounded-full bg-orange-100 text-orange-600 font-bold text-sm flex items-center justify-center mx-auto mb-3">1</div>
        <h3 class="font-semibold text-stone-800 mb-1.5">Podaj trase</h3>
        <p class="text-stone-500 text-sm">
          Wpisz numery pociagow i stacje. Pokaz emy Ci czas przesiadki i aktualne opoznienia.
        </p>
      </div>
      <div class="text-center">
        <div class="w-10 h-10 rounded-full bg-orange-100 text-orange-600 font-bold text-sm flex items-center justify-center mx-auto mb-3">2</div>
        <h3 class="font-semibold text-stone-800 mb-1.5">Wlacz monitoring</h3>
        <p class="text-stone-500 text-sm">
          Za 5 zl monitorujemy Twoj pociag. Jesli opoznienie zagrozi przesiadce — dostaniesz powiadomienie.
        </p>
      </div>
      <div class="text-center">
        <div class="w-10 h-10 rounded-full bg-orange-100 text-orange-600 font-bold text-sm flex items-center justify-center mx-auto mb-3">3</div>
        <h3 class="font-semibold text-stone-800 mb-1.5">Reaguj na czas</h3>
        <p class="text-stone-500 text-sm">
          Podpowiemy alternatywne polaczenia. Jesli opoznienie przekroczy 60 min — pomozemy zlozyc reklamacje.
        </p>
      </div>
    </div>
  </section>

  <!-- Social proof: the pain is real -->
  <section class="bg-white border-y border-stone-200">
    <div class="max-w-4xl mx-auto px-4 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-2xl font-bold text-stone-900">~73%</div>
          <div class="text-xs text-stone-400 mt-1">Punktualnosc PKP IC</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-orange-500">1 na 4</div>
          <div class="text-xs text-stone-400 mt-1">Pociagow sie spoznia</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-stone-900">78.5M</div>
          <div class="text-xs text-stone-400 mt-1">Pasazerow rocznie</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-stone-900">0</div>
          <div class="text-xs text-stone-400 mt-1">Narzedzi do monitoringu przesiadek</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Example scenario — makes it concrete -->
  <section class="max-w-4xl mx-auto px-4 py-14">
    <h2 class="text-center text-sm font-semibold text-stone-400 uppercase tracking-wider mb-8">Przyklad</h2>
    <div class="max-w-lg mx-auto">
      <div class="bg-white rounded-2xl border border-stone-200 overflow-hidden">
        <!-- Train 1 -->
        <div class="p-4 border-b border-stone-100">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-stone-700">IC 5313</span>
            <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">+18 min</span>
          </div>
          <div class="text-xs text-stone-400">Krakow Glowny &rarr; Warszawa Centralna</div>
          <div class="text-xs text-stone-400">Przyjazd: <span class="line-through">13:45</span> <span class="text-amber-600 font-medium">~14:03</span></div>
        </div>

        <!-- Transfer -->
        <div class="px-4 py-3 bg-stone-50 flex items-center justify-between">
          <div class="text-xs text-stone-500">
            Przesiadka w <span class="font-medium text-stone-700">Warszawa Centralna</span>
          </div>
          <div class="text-xs">
            <span class="font-semibold text-amber-600">Zostalo 12 min</span>
            <span class="text-stone-400"> z 30 min</span>
          </div>
        </div>

        <!-- Train 2 -->
        <div class="p-4 border-t border-stone-100">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-stone-700">EIC 1701</span>
            <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Punktualnie</span>
          </div>
          <div class="text-xs text-stone-400">Warszawa Centralna &rarr; Gdansk Glowny</div>
          <div class="text-xs text-stone-400">Odjazd: 14:15</div>
        </div>

        <!-- CTA -->
        <div class="p-4 bg-orange-50 border-t border-orange-100">
          <button class="w-full py-2.5 bg-orange-500 hover:bg-orange-600 text-white font-semibold rounded-xl transition-colors text-sm">
            Monitoruj te przesiadke — 5 zl
          </button>
          <p class="text-center text-xs text-stone-400 mt-2">
            Dostaniesz powiadomienie jesli opoznienie sie zwiez. Podpowiemy alternatywy.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Simple delay check — secondary action -->
  <section class="bg-white border-y border-stone-200">
    <div class="max-w-4xl mx-auto px-4 py-12">
      <div class="max-w-md mx-auto text-center">
        <h2 class="text-lg font-semibold text-stone-800 mb-2">Sprawdz opoznienie pociagu</h2>
        <p class="text-sm text-stone-400 mb-4">Bez przesiadki? Sprawdz czy Twoj pociag jedzie na czas.</p>
        <form class="flex gap-2">
          <input
            type="text"
            placeholder="Numer pociagu, np. IC 350"
            class="flex-1 px-3.5 py-2.5 bg-stone-50 border border-stone-300 rounded-lg text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-orange-500/30 focus:border-orange-500 transition-all text-sm"
          />
          <button
            type="submit"
            class="px-5 py-2.5 bg-stone-800 hover:bg-stone-700 text-white font-medium rounded-lg transition-colors text-sm"
          >
            Sprawdz
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="max-w-4xl mx-auto px-4 py-16 text-center">
    <h2 class="text-2xl font-bold text-stone-900 mb-3">Nie daj sie zaskoczyc opoznieniem</h2>
    <p class="text-stone-500 mb-6 max-w-md mx-auto">
      Za 5 zl monitorujemy Twoja przesiadke i damy Ci znac jesli cos pojdzie nie tak.
    </p>
    <a href="#top" class="inline-block px-8 py-3 bg-orange-500 hover:bg-orange-600 text-white font-semibold rounded-xl transition-colors text-sm">
      Sprawdz przesiadke
    </a>
  </section>

</Base>
