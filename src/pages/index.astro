---
import Base from '../layouts/Base.astro';
---
<Base title="Opoznienia pociagow PKP w czasie rzeczywistym">
  <section class="text-center py-16">
    <h1 class="text-5xl font-bold mb-4">
      <span class="text-red-500">Nie jedzie?</span>
    </h1>
    <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-8">
      Sprawdz opoznienia pociagow PKP w czasie rzeczywistym.
      Monitoruj przesiadki. Odzyskaj pieniadze za opoznienia.
    </p>

    <div class="max-w-md mx-auto">
      <form class="flex gap-2">
        <input
          type="text"
          placeholder="Numer pociagu, np. IC 350"
          class="flex-1 px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-gray-100 placeholder-gray-500 focus:outline-none focus:border-red-500 transition-colors"
        />
        <button
          type="submit"
          class="px-6 py-3 bg-red-600 hover:bg-red-500 text-white font-medium rounded-lg transition-colors"
        >
          Sprawdz
        </button>
      </form>
    </div>
  </section>

  <section class="grid md:grid-cols-3 gap-6 mt-8">
    <div class="p-6 bg-gray-900 rounded-xl border border-gray-800">
      <div class="text-3xl mb-3">&#x23F1;</div>
      <h2 class="text-lg font-semibold mb-2">Opoznienia na zywo</h2>
      <p class="text-gray-400 text-sm">
        Sprawdz czy Twoj pociag jedzie punktualnie. Dane aktualizowane w czasie rzeczywistym z systemu PKP PLK.
      </p>
    </div>

    <div class="p-6 bg-gray-900 rounded-xl border border-gray-800">
      <div class="text-3xl mb-3">&#x1F504;</div>
      <h2 class="text-lg font-semibold mb-2">Monitor przesiadek</h2>
      <p class="text-gray-400 text-sm">
        Podaj trase z przesiadka. Dostaniesz alert jesli opoznienie zagrozi Twojemu polaczeniu.
      </p>
    </div>

    <div class="p-6 bg-gray-900 rounded-xl border border-gray-800">
      <div class="text-3xl mb-3">&#x1F4B0;</div>
      <h2 class="text-lg font-semibold mb-2">Odzyskaj odszkodowanie</h2>
      <p class="text-gray-400 text-sm">
        Opoznienie 60+ minut? Przygotujemy reklamacje do PKP Intercity i pomozemy odzyskac pieniadze.
      </p>
    </div>
  </section>

  <section class="mt-16 text-center">
    <h2 class="text-2xl font-bold mb-4">Punktualnosc PKP Intercity</h2>
    <p class="text-gray-400 mb-8">Na podstawie danych z Otwartych Danych Kolejowych PKP PLK</p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-2xl mx-auto">
      <div class="p-4 bg-gray-900 rounded-lg border border-gray-800">
        <div class="text-2xl font-bold text-red-400">~73%</div>
        <div class="text-xs text-gray-500 mt-1">Punktualnosc Q3 2024</div>
      </div>
      <div class="p-4 bg-gray-900 rounded-lg border border-gray-800">
        <div class="text-2xl font-bold text-yellow-400">78.5M</div>
        <div class="text-xs text-gray-500 mt-1">Pasazerow w 2024</div>
      </div>
      <div class="p-4 bg-gray-900 rounded-lg border border-gray-800">
        <div class="text-2xl font-bold text-gray-300">1 na 4</div>
        <div class="text-xs text-gray-500 mt-1">Pociagow sie spoznia</div>
      </div>
      <div class="p-4 bg-gray-900 rounded-lg border border-gray-800">
        <div class="text-2xl font-bold text-green-400">25-50%</div>
        <div class="text-xs text-gray-500 mt-1">Zwrot za opoznienie 60+ min</div>
      </div>
    </div>
  </section>
</Base>
