---
import Base from '../layouts/Base.astro';
---
<Base title="Monitor przesiadek PKP — dostaniesz alert jeśli nie zdążysz">

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/hero-train.jpg"
        alt="Pociąg PKP na peronie dworca kolejowego w Polsce"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-surface-dark/70 via-surface-dark/80 to-surface-dark/95"></div>
    </div>

    <div class="relative max-w-5xl mx-auto px-5 pt-16 pb-20">
      <div class="max-w-2xl mx-auto text-center mb-10">
        <p class="font-ticket text-brand-200 text-sm tracking-widest uppercase mb-4">Monitor przesiadek</p>
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight leading-[1.1]">
          Masz przesiadkę?<br/>
          <span class="text-brand-400">Sprawdzimy czy zdążysz.</span>
        </h1>
        <p class="text-lg text-white/60 max-w-lg mx-auto">
          Monitorujemy Twój pociąg i wyślemy alert jeśli opóźnienie zagrozi połączeniu.
        </p>
      </div>

      <!-- Przesiadki form — ticket-style card -->
      <div class="max-w-lg mx-auto bg-surface-raised rounded-2xl shadow-2xl overflow-hidden">
        <form class="p-5 md:p-6 space-y-4">
          <div>
            <label class="block text-xs font-semibold text-ink-muted mb-2 tracking-wider uppercase">Pociąg 1 — skąd jedziesz</label>
            <div class="grid grid-cols-2 gap-2">
              <input type="text" placeholder="np. IC 5313" class="input font-ticket" />
              <input type="text" placeholder="Stacja odjazdu" class="input" />
            </div>
          </div>

          <!-- Perforated divider -->
          <div class="ticket-divider my-5"></div>

          <div>
            <label class="block text-xs font-semibold text-ink-muted mb-2 tracking-wider uppercase">Pociąg 2 — dokąd jedziesz</label>
            <div class="grid grid-cols-2 gap-2">
              <input type="text" placeholder="np. EIC 1701" class="input font-ticket" />
              <input type="text" placeholder="Stacja docelowa" class="input" />
            </div>
          </div>

          <button type="submit" class="btn-primary w-full mt-2">
            Sprawdź przesiadkę
          </button>
        </form>

        <div class="px-6 pb-4 text-center">
          <p class="text-xs text-ink-faint">
            Dane z systemu PKP PLK &middot; Aktualizowane co minutę
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="max-w-5xl mx-auto px-5 py-20">
    <p class="text-center text-xs font-semibold text-ink-faint uppercase tracking-[0.2em] mb-12">Jak to działa</p>
    <div class="grid md:grid-cols-3 gap-10">
      <div>
        <div class="w-9 h-9 rounded-lg bg-brand-100 text-brand-600 font-bold text-sm flex items-center justify-center mb-4">1</div>
        <h3 class="font-bold text-ink mb-2">Podaj trasę</h3>
        <p class="text-ink-muted text-sm leading-relaxed">
          Wpisz numery pociągów i stacje. Pokażemy Ci czas przesiadki i aktualne opóźnienia.
        </p>
      </div>
      <div>
        <div class="w-9 h-9 rounded-lg bg-brand-100 text-brand-600 font-bold text-sm flex items-center justify-center mb-4">2</div>
        <h3 class="font-bold text-ink mb-2">Włącz monitoring — <span class="font-ticket text-brand-500">5 zł</span></h3>
        <p class="text-ink-muted text-sm leading-relaxed">
          Monitorujemy Twój pociąg w czasie rzeczywistym. Jeśli opóźnienie zagrozi przesiadce — dostaniesz powiadomienie push.
        </p>
      </div>
      <div>
        <div class="w-9 h-9 rounded-lg bg-brand-100 text-brand-600 font-bold text-sm flex items-center justify-center mb-4">3</div>
        <h3 class="font-bold text-ink mb-2">Reaguj na czas</h3>
        <p class="text-ink-muted text-sm leading-relaxed">
          Podpowiemy alternatywne połączenia. Jeśli opóźnienie przekroczy 60 min — pomożemy złożyć reklamację.
        </p>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="bg-surface-dark">
    <div class="max-w-5xl mx-auto px-5 py-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="stat-value text-white">~73%</div>
          <div class="text-xs text-white/40 mt-2 font-ticket uppercase tracking-wider">Punktualność PKP IC</div>
        </div>
        <div>
          <div class="stat-value text-brand-400">1 na 4</div>
          <div class="text-xs text-white/40 mt-2 font-ticket uppercase tracking-wider">Pociągów się spóźnia</div>
        </div>
        <div>
          <div class="stat-value text-white">78,5M</div>
          <div class="text-xs text-white/40 mt-2 font-ticket uppercase tracking-wider">Pasażerów rocznie</div>
        </div>
        <div>
          <div class="stat-value text-white">0</div>
          <div class="text-xs text-white/40 mt-2 font-ticket uppercase tracking-wider">Narzędzi do przesiadek</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Example scenario — ticket card -->
  <section class="max-w-5xl mx-auto px-5 py-20">
    <p class="text-center text-xs font-semibold text-ink-faint uppercase tracking-[0.2em] mb-10">Przykład na żywo</p>
    <div class="max-w-md mx-auto">
      <div class="ticket-card rounded-2xl overflow-hidden shadow-lg">
        <!-- Train 1 -->
        <div class="p-5">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
              <span class="font-ticket font-semibold text-ink text-sm">IC 5313</span>
              <span class="badge badge-warn">+18 min</span>
            </div>
            <span class="font-ticket text-xs text-ink-faint">26.03.2026</span>
          </div>
          <div class="flex items-center gap-3 text-sm">
            <div>
              <div class="font-ticket font-medium text-ink">13:45</div>
              <div class="text-xs text-ink-faint">Kraków Gł.</div>
            </div>
            <div class="flex-1 flex items-center gap-1.5 px-2">
              <div class="w-1.5 h-1.5 rounded-full bg-brand-500"></div>
              <div class="flex-1 border-t border-dashed border-ink-faint/30"></div>
              <div class="text-[10px] text-ink-faint font-ticket">2h 53m</div>
              <div class="flex-1 border-t border-dashed border-ink-faint/30"></div>
              <div class="w-1.5 h-1.5 rounded-full bg-ink-faint"></div>
            </div>
            <div class="text-right">
              <div class="font-ticket font-medium text-ink"><span class="line-through text-ink-faint">13:45</span> <span class="text-delay-warn">14:03</span></div>
              <div class="text-xs text-ink-faint">Warszawa C.</div>
            </div>
          </div>
        </div>

        <!-- Perforated transfer divider -->
        <div class="ticket-divider"></div>

        <!-- Transfer info -->
        <div class="px-5 py-3 bg-surface-sunken flex items-center justify-between">
          <div class="text-xs text-ink-muted">
            Przesiadka: <span class="font-semibold text-ink">Warszawa Centralna</span>
          </div>
          <div class="font-ticket text-xs">
            <span class="font-semibold text-delay-warn">12 min</span>
            <span class="text-ink-faint"> / 30 min</span>
          </div>
        </div>

        <!-- Perforated divider -->
        <div class="ticket-divider"></div>

        <!-- Train 2 -->
        <div class="p-5">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
              <span class="font-ticket font-semibold text-ink text-sm">EIC 1701</span>
              <span class="badge badge-safe">Punktualnie</span>
            </div>
            <span class="font-ticket text-xs text-ink-faint">26.03.2026</span>
          </div>
          <div class="flex items-center gap-3 text-sm">
            <div>
              <div class="font-ticket font-medium text-ink">14:15</div>
              <div class="text-xs text-ink-faint">Warszawa C.</div>
            </div>
            <div class="flex-1 flex items-center gap-1.5 px-2">
              <div class="w-1.5 h-1.5 rounded-full bg-delay-safe"></div>
              <div class="flex-1 border-t border-dashed border-ink-faint/30"></div>
              <div class="text-[10px] text-ink-faint font-ticket">3h 21m</div>
              <div class="flex-1 border-t border-dashed border-ink-faint/30"></div>
              <div class="w-1.5 h-1.5 rounded-full bg-ink-faint"></div>
            </div>
            <div class="text-right">
              <div class="font-ticket font-medium text-ink">17:36</div>
              <div class="text-xs text-ink-faint">Gdańsk Gł.</div>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div class="p-5 bg-gradient-to-b from-brand-50 to-brand-100/50 border-t border-brand-200">
          <button class="btn-primary w-full">
            Monitoruj tę przesiadkę — 5 zł
          </button>
          <p class="text-center text-xs text-ink-muted mt-3">
            Powiadomienie push + alternatywne połączenia + sprawdzenie odszkodowania
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Simple delay check -->
  <section class="border-t border-border bg-surface-raised">
    <div class="max-w-5xl mx-auto px-5 py-14">
      <div class="max-w-md mx-auto text-center">
        <h2 class="text-xl font-bold text-ink mb-2">Sprawdź opóźnienie pociągu</h2>
        <p class="text-sm text-ink-muted mb-5">Bez przesiadki? Sprawdź czy Twój pociąg jedzie na czas.</p>
        <form class="flex gap-2">
          <input type="text" placeholder="Numer pociągu, np. IC 350" class="input font-ticket" />
          <button type="submit" class="btn-secondary shrink-0">Sprawdź</button>
        </form>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="max-w-5xl mx-auto px-5 py-20 text-center">
    <h2 class="text-3xl font-extrabold text-ink mb-4 tracking-tight">Nie daj się zaskoczyć opóźnieniem</h2>
    <p class="text-ink-muted mb-8 max-w-md mx-auto leading-relaxed">
      Za <span class="font-ticket font-semibold text-brand-500">5 zł</span> monitorujemy Twoją przesiadkę i damy Ci znać jeśli coś pójdzie nie tak.
    </p>
    <a href="#top" class="btn-primary">
      Sprawdź przesiadkę
    </a>
  </section>

</Base>
