---
import Base from '../layouts/Base.astro';
---
<Base title="Monitor przesiadek PKP — dostaniesz alert jeśli nie zdążysz">

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/hero-train.jpg"
        alt="Pociąg PKP na peronie dworca kolejowego w Polsce"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-surface-dark/60 via-surface-dark/75 to-surface-dark"></div>
    </div>

    <div class="relative max-w-5xl mx-auto px-5 pt-20 pb-24">
      <div class="max-w-2xl mx-auto text-center mb-12">
        <p class="section-label text-brand-300 mb-5">// monitor przesiadek</p>
        <h1 class="text-[2.75rem] md:text-[3.5rem] font-extrabold text-white leading-[1.05] tracking-tight mb-5">
          Masz przesiadkę?<br/>
          <span class="text-brand-300">Sprawdzimy czy zdążysz.</span>
        </h1>
        <p class="text-[1.0625rem] text-white/50 max-w-md mx-auto leading-relaxed">
          Monitorujemy Twój pociąg i wyślemy alert jeśli opóźnienie zagrozi połączeniu.
        </p>
      </div>

      <!-- Form card -->
      <div class="max-w-lg mx-auto">
        <div class="bg-surface-raised rounded-2xl shadow-2xl overflow-hidden ring-1 ring-white/10">
          <form class="p-6 space-y-5">
            <div>
              <label class="section-label text-ink-muted block mb-2.5">Pociąg 1 — skąd jedziesz</label>
              <div class="grid grid-cols-2 gap-2.5">
                <input type="text" placeholder="np. IC 5313" class="input input-mono" />
                <input type="text" placeholder="Stacja odjazdu" class="input" />
              </div>
            </div>

            <div class="ticket-divider my-6"></div>

            <div>
              <label class="section-label text-ink-muted block mb-2.5">Pociąg 2 — dokąd jedziesz</label>
              <div class="grid grid-cols-2 gap-2.5">
                <input type="text" placeholder="np. EIC 1701" class="input input-mono" />
                <input type="text" placeholder="Stacja docelowa" class="input" />
              </div>
            </div>

            <button type="submit" class="btn-primary w-full mt-1">
              Sprawdź przesiadkę
            </button>
          </form>

          <div class="px-6 pb-5 text-center">
            <p class="font-ticket text-[0.625rem] text-ink-faint tracking-wider uppercase">
              Dane: PKP PLK Otwarte Dane Kolejowe &middot; Odświeżane co 60s
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="max-w-5xl mx-auto px-5 py-24 fade-up">
    <p class="section-label text-center mb-14">// jak to działa</p>
    <div class="grid md:grid-cols-3 gap-12 stagger">
      <div class="fade-up">
        <div class="step-number mb-5">01</div>
        <h3 class="text-[1.0625rem] font-bold text-ink mb-2.5 tracking-tight">Podaj trasę</h3>
        <p class="text-ink-muted text-[0.9375rem] leading-relaxed">
          Wpisz numery pociągów i stacje. Pokażemy czas przesiadki i&nbsp;aktualne opóźnienia.
        </p>
      </div>
      <div class="fade-up">
        <div class="step-number mb-5">02</div>
        <h3 class="text-[1.0625rem] font-bold text-ink mb-2.5 tracking-tight">Włącz monitoring</h3>
        <p class="text-ink-muted text-[0.9375rem] leading-relaxed">
          Za <span class="font-ticket font-semibold text-brand-500">15&nbsp;zł/msc</span> monitorujemy wszystkie Twoje przesiadki. Jeśli opóźnienie zagrozi połączeniu — dostaniesz powiadomienie push.
        </p>
      </div>
      <div class="fade-up">
        <div class="step-number mb-5">03</div>
        <h3 class="text-[1.0625rem] font-bold text-ink mb-2.5 tracking-tight">Reaguj na czas</h3>
        <p class="text-ink-muted text-[0.9375rem] leading-relaxed">
          Podpowiemy alternatywne połączenia. Jeśli opóźnienie przekroczy 60&nbsp;min — pomożemy złożyć reklamację.
        </p>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-surface-dark rounded-3xl mx-4 md:mx-8 lg:mx-auto lg:max-w-5xl fade-up">
    <div class="px-8 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="stat-value text-white">~73%</div>
          <p class="font-ticket text-[0.625rem] text-white/30 mt-3 tracking-wider uppercase">Punktualność PKP IC</p>
        </div>
        <div>
          <div class="stat-value text-brand-400">1 na 4</div>
          <p class="font-ticket text-[0.625rem] text-white/30 mt-3 tracking-wider uppercase">Pociągów się spóźnia</p>
        </div>
        <div>
          <div class="stat-value text-white">78,5M</div>
          <p class="font-ticket text-[0.625rem] text-white/30 mt-3 tracking-wider uppercase">Pasażerów rocznie</p>
        </div>
        <div>
          <div class="stat-value text-white/40">0</div>
          <p class="font-ticket text-[0.625rem] text-white/30 mt-3 tracking-wider uppercase">Narzędzi do przesiadek</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Example ticket -->
  <section class="max-w-5xl mx-auto px-5 py-24 fade-up">
    <p class="section-label text-center mb-12">// przykład na żywo</p>
    <div class="max-w-md mx-auto">
      <div class="ticket-card rounded-2xl overflow-hidden shadow-lg">
        <!-- Train 1 -->
        <div class="p-5 pb-4">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-2.5">
              <span class="font-ticket font-semibold text-[0.875rem] text-ink">IC 5313</span>
              <span class="badge badge-warn">+18 min</span>
            </div>
            <span class="font-ticket text-[0.6875rem] text-ink-faint">26.03.2026</span>
          </div>
          <div class="route-line">
            <div class="text-right min-w-[4.5rem]">
              <div class="font-ticket font-medium text-[0.875rem] text-ink">11:10</div>
              <div class="text-[0.6875rem] text-ink-faint">Kraków Gł.</div>
            </div>
            <div class="route-dot bg-brand-500"></div>
            <div class="route-dash"></div>
            <div class="route-duration">2h 53m</div>
            <div class="route-dash"></div>
            <div class="route-dot bg-ink-faint"></div>
            <div class="min-w-[4.5rem]">
              <div class="font-ticket font-medium text-[0.875rem] text-ink">
                <span class="line-through text-ink-faint decoration-ink-faint/50">13:45</span>
                <span class="text-delay-warn ml-1">14:03</span>
              </div>
              <div class="text-[0.6875rem] text-ink-faint">Warszawa C.</div>
            </div>
          </div>
        </div>

        <!-- Transfer -->
        <div class="ticket-divider"></div>
        <div class="px-5 py-3.5 bg-surface-sunken">
          <div class="flex items-center justify-between">
            <div class="text-[0.8125rem] text-ink-muted">
              Przesiadka: <span class="font-semibold text-ink">Warszawa Centralna</span>
            </div>
            <div class="font-ticket text-[0.75rem]">
              <span class="font-semibold text-delay-warn">12 min</span>
              <span class="text-ink-faint"> / 30</span>
            </div>
          </div>
        </div>
        <div class="ticket-divider"></div>

        <!-- Train 2 -->
        <div class="p-5 pb-4">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-2.5">
              <span class="font-ticket font-semibold text-[0.875rem] text-ink">EIC 1701</span>
              <span class="badge badge-safe">Punktualnie</span>
            </div>
            <span class="font-ticket text-[0.6875rem] text-ink-faint">26.03.2026</span>
          </div>
          <div class="route-line">
            <div class="text-right min-w-[4.5rem]">
              <div class="font-ticket font-medium text-[0.875rem] text-ink">14:15</div>
              <div class="text-[0.6875rem] text-ink-faint">Warszawa C.</div>
            </div>
            <div class="route-dot bg-delay-safe"></div>
            <div class="route-dash"></div>
            <div class="route-duration">3h 21m</div>
            <div class="route-dash"></div>
            <div class="route-dot bg-ink-faint"></div>
            <div class="min-w-[4.5rem]">
              <div class="font-ticket font-medium text-[0.875rem] text-ink">17:36</div>
              <div class="text-[0.6875rem] text-ink-faint">Gdańsk Gł.</div>
            </div>
          </div>
        </div>

        <!-- CTA — push monthly -->
        <div class="p-5 bg-brand-50 border-t border-brand-200">
          <a href="/premium" class="btn-primary w-full text-center block">
            Monitoruj bez limitu — 15 zł/msc
          </a>
          <p class="text-center text-[0.75rem] text-ink-muted mt-2.5">
            Nielimitowane przesiadki &middot; Priorytetowe alerty &middot; Historia tras
          </p>
          <p class="text-center mt-2">
            <a href="/cennik" class="text-[0.75rem] text-ink-faint hover:text-ink transition-colors underline underline-offset-2">
              Tylko ta przesiadka? 5 zł jednorazowo
            </a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing — monthly first and dominant -->
  <section class="max-w-5xl mx-auto px-5 py-24 fade-up">
    <p class="section-label text-center mb-4">// cennik</p>
    <h2 class="text-[1.75rem] md:text-[2rem] font-extrabold text-ink text-center mb-3 tracking-tight">Spokój za cenę kawy</h2>
    <p class="text-ink-muted text-center mb-14 max-w-md mx-auto">Pełen monitoring przesiadek za 15&nbsp;zł/msc. Albo jednorazowo, jeśli jedziesz raz.</p>

    <div class="grid md:grid-cols-2 gap-5 max-w-2xl mx-auto">
      <!-- Monthly — dominant, first on mobile -->
      <div class="bg-surface-raised rounded-2xl border-2 border-brand-500 p-6 flex flex-col relative shadow-lg shadow-brand-500/10 md:order-2">
        <div class="absolute -top-3 left-6">
          <span class="font-ticket text-[0.625rem] font-semibold tracking-wider uppercase bg-brand-500 text-white px-3 py-1 rounded-md">Polecany</span>
        </div>
        <div class="mb-5">
          <p class="section-label text-brand-500 mb-3">Miesięczny</p>
          <div class="flex items-baseline gap-1">
            <span class="font-ticket text-[2.5rem] font-bold text-ink tracking-tight">15 zł</span>
            <span class="text-ink-faint text-sm">/ miesiąc</span>
          </div>
          <p class="text-[0.8125rem] text-brand-600 font-medium mt-1">3 przesiadki = subskrypcja się zwraca</p>
        </div>
        <ul class="space-y-3 text-[0.875rem] text-ink-secondary mb-8 flex-1">
          <li class="flex items-start gap-2.5">
            <span class="text-brand-500 mt-0.5 font-bold">&#10003;</span>
            <strong>Nielimitowany</strong> monitoring wszystkich przesiadek
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-brand-500 mt-0.5 font-bold">&#10003;</span>
            Automatyczne śledzenie po podaniu numeru pociągu
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-brand-500 mt-0.5 font-bold">&#10003;</span>
            <strong>Priorytetowe</strong> powiadomienia push
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-brand-500 mt-0.5 font-bold">&#10003;</span>
            Historia opóźnień Twoich tras
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-brand-500 mt-0.5 font-bold">&#10003;</span>
            Alternatywne połączenia + odszkodowania
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-brand-500 mt-0.5 font-bold">&#10003;</span>
            Pomoc w składaniu reklamacji
          </li>
        </ul>
        <a href="/premium" class="btn-primary w-full text-center">Zacznij za 15 zł/msc</a>
        <p class="text-center text-[0.6875rem] text-ink-faint mt-3">Anulujesz kiedy chcesz. Bez zobowiązań.</p>
      </div>

      <!-- One-time — secondary, "just once?" framing -->
      <div class="bg-surface-raised rounded-2xl border border-border p-6 flex flex-col md:order-1">
        <div class="mb-5">
          <p class="section-label text-ink-faint mb-3">Jednorazowy</p>
          <div class="flex items-baseline gap-1">
            <span class="font-ticket text-[2rem] font-bold text-ink tracking-tight">5 zł</span>
            <span class="text-ink-faint text-sm">/ przesiadka</span>
          </div>
          <p class="text-[0.75rem] text-ink-faint mt-1">Jedziesz raz? To opcja dla Ciebie.</p>
        </div>
        <ul class="space-y-3 text-[0.875rem] text-ink-secondary mb-8 flex-1">
          <li class="flex items-start gap-2.5">
            <span class="text-delay-safe mt-0.5">&#10003;</span>
            Monitoring jednej przesiadki w czasie rzeczywistym
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-delay-safe mt-0.5">&#10003;</span>
            Powiadomienie push jeśli opóźnienie zagraża połączeniu
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-delay-safe mt-0.5">&#10003;</span>
            Propozycje alternatywnych połączeń
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-delay-safe mt-0.5">&#10003;</span>
            Sprawdzenie prawa do odszkodowania
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-ink-faint mt-0.5">&#10007;</span>
            <span class="text-ink-faint">Brak historii tras</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-ink-faint mt-0.5">&#10007;</span>
            <span class="text-ink-faint">Brak priorytetowych powiadomień</span>
          </li>
        </ul>
        <a href="/cennik" class="btn-secondary w-full text-center">Kup jednorazowo &mdash; 5 zł</a>
      </div>
    </div>

    <p class="text-center text-[0.8125rem] text-ink-faint mt-8">
      Sprawdzanie opóźnień i statystyk jest <strong class="text-ink">zawsze darmowe</strong>.
      Płacisz tylko za monitoring przesiadek z powiadomieniami.
    </p>
  </section>

  <!-- Quick links to tools + cities -->
  <section class="max-w-5xl mx-auto px-5 py-20 fade-up">
    <p class="section-label text-center mb-4">// odkryj więcej</p>
    <h2 class="text-[1.5rem] font-extrabold text-ink text-center mb-10 tracking-tight">Sprawdź opóźnienia w swoim mieście</h2>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-10">
      <a href="/opoznienia/warszawa" class="bg-surface-raised rounded-xl border border-border p-4 hover:border-brand-400 hover:shadow-md transition-all group">
        <p class="font-semibold text-ink group-hover:text-brand-500 transition-colors">Warszawa</p>
        <p class="font-ticket text-[0.6875rem] text-ink-faint">342 pociągi/dzień</p>
      </a>
      <a href="/opoznienia/krakow" class="bg-surface-raised rounded-xl border border-border p-4 hover:border-brand-400 hover:shadow-md transition-all group">
        <p class="font-semibold text-ink group-hover:text-brand-500 transition-colors">Kraków</p>
        <p class="font-ticket text-[0.6875rem] text-ink-faint">278 pociągów/dzień</p>
      </a>
      <a href="/opoznienia/gdansk" class="bg-surface-raised rounded-xl border border-border p-4 hover:border-brand-400 hover:shadow-md transition-all group">
        <p class="font-semibold text-ink group-hover:text-brand-500 transition-colors">Gdańsk</p>
        <p class="font-ticket text-[0.6875rem] text-ink-faint">215 pociągów/dzień</p>
      </a>
      <a href="/opoznienia/wroclaw" class="bg-surface-raised rounded-xl border border-border p-4 hover:border-brand-400 hover:shadow-md transition-all group">
        <p class="font-semibold text-ink group-hover:text-brand-500 transition-colors">Wrocław</p>
        <p class="font-ticket text-[0.6875rem] text-ink-faint">198 pociągów/dzień</p>
      </a>
      <a href="/opoznienia/poznan" class="bg-surface-raised rounded-xl border border-border p-4 hover:border-brand-400 hover:shadow-md transition-all group">
        <p class="font-semibold text-ink group-hover:text-brand-500 transition-colors">Poznań</p>
        <p class="font-ticket text-[0.6875rem] text-ink-faint">186 pociągów/dzień</p>
      </a>
      <a href="/opoznienia/katowice" class="bg-surface-raised rounded-xl border border-border p-4 hover:border-brand-400 hover:shadow-md transition-all group">
        <p class="font-semibold text-ink group-hover:text-brand-500 transition-colors">Katowice</p>
        <p class="font-ticket text-[0.6875rem] text-ink-faint">224 pociągi/dzień</p>
      </a>
      <a href="/opoznienia/szczecin" class="bg-surface-raised rounded-xl border border-border p-4 hover:border-brand-400 hover:shadow-md transition-all group">
        <p class="font-semibold text-ink group-hover:text-brand-500 transition-colors">Szczecin</p>
        <p class="font-ticket text-[0.6875rem] text-ink-faint">124 pociągi/dzień</p>
      </a>
      <a href="/opoznienia/lodz" class="bg-surface-raised rounded-xl border border-border p-4 hover:border-brand-400 hover:shadow-md transition-all group">
        <p class="font-semibold text-ink group-hover:text-brand-500 transition-colors">Łódź</p>
        <p class="font-ticket text-[0.6875rem] text-ink-faint">156 pociągów/dzień</p>
      </a>
    </div>

    <div class="flex flex-wrap justify-center gap-3">
      <a href="/opoznienia/dzisiaj" class="btn-secondary text-[0.8125rem]">Opóźnienia dzisiaj</a>
      <a href="/gdzie-jest-pociag" class="btn-secondary text-[0.8125rem]">Znajdź pociąg</a>
      <a href="/punktualnosc" class="btn-secondary text-[0.8125rem]">Statystyki punktualności</a>
    </div>
  </section>

  <!-- Delay check -->
  <section class="border-t border-border bg-surface-raised">
    <div class="max-w-5xl mx-auto px-5 py-16">
      <div class="max-w-md mx-auto text-center">
        <h2 class="text-xl font-bold text-ink mb-2 tracking-tight">Sprawdź opóźnienie pociągu</h2>
        <p class="text-[0.875rem] text-ink-muted mb-5">Bez przesiadki? Sprawdź czy Twój pociąg jedzie na czas.</p>
        <form class="flex gap-2.5">
          <input type="text" placeholder="Numer pociągu, np. IC 350" class="input input-mono" />
          <button type="submit" class="btn-secondary shrink-0">Sprawdź</button>
        </form>
      </div>
    </div>
  </section>

  <!-- Bottom CTA — subscription nudge -->
  <section class="max-w-5xl mx-auto px-5 py-24 text-center fade-up">
    <h2 class="text-[2rem] md:text-[2.5rem] font-extrabold text-ink mb-5 tracking-tight leading-tight">
      Nie daj się zaskoczyć<br/>opóźnieniem
    </h2>
    <p class="text-ink-muted mb-8 max-w-md mx-auto text-[1.0625rem] leading-relaxed">
      Plan miesięczny = nielimitowany monitoring przesiadek. Raz włączasz, reszta dzieje się automatycznie.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/premium" class="btn-primary">
        Plan miesięczny &mdash; 15 zł/msc
      </a>
      <a href="#top" class="btn-secondary">
        Sprawdź przesiadkę za darmo
      </a>
    </div>
    <p class="text-[0.8125rem] text-ink-faint mt-5">3 przesiadki w miesiącu? Subskrypcja już się zwraca.</p>
  </section>

</Base>
