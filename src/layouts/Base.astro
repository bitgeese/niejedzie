---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Masz przesiadkę? Sprawdzimy czy zdążysz. Monitoruj połączenia PKP w czasie rzeczywistym i dostaniesz alert jeśli opóźnienie zagrozi Twojej przesiadce.', ogImage = '/og-default.png' } = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
const fullTitle = `${title} | niejedzie.pl`;
---
<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="IQTr8YBM-ZwE2PzVB6rexR2CyiWZNPG7rtw7LvtkfaM" />
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/icon-192.png" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#ea580c" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:site_name" content="niejedzie.pl" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl.href} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

    <title>{fullTitle}</title>

    <!-- Extra head content (Schema.org, etc.) -->
    <slot name="head" />

    <!-- Plausible Analytics -->
    <script defer data-domain="niejedzie.pl" src="https://plausible.io/js/script.js"></script>

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "niejedzie.pl",
      "url": "https://niejedzie.pl",
      "description": "Monitor przesiadek i opóźnień pociągów PKP w czasie rzeczywistym.",
      "applicationCategory": "TravelApplication",
      "operatingSystem": "Web",
      "offers": {
        "@type": "Offer",
        "price": "5.00",
        "priceCurrency": "PLN",
        "description": "Jednorazowy monitoring przesiadki"
      },
      "inLanguage": "pl",
      "provider": {
        "@type": "Organization",
        "name": "niejedzie.pl"
      }
    })} />
  </head>
  <body>
    <header class="sticky top-0 z-50 bg-surface-raised/80 backdrop-blur-lg border-b border-border">
      <nav class="max-w-5xl mx-auto px-5 py-3.5 flex items-center justify-between">
        <a href="/" class="group flex items-baseline gap-0.5">
          <span class="text-lg font-bold tracking-tight text-ink">nie</span><span class="text-lg font-bold tracking-tight text-brand-500">jedzie</span><span class="text-sm font-normal text-ink-faint">.pl</span>
        </a>
        <div class="flex items-center gap-1">
          <a href="/opoznienia" class="px-3 py-1.5 text-sm text-ink-muted hover:text-ink hover:bg-surface-sunken rounded-lg transition-all">Opóźnienia</a>
          <a href="/statystyki" class="px-3 py-1.5 text-sm text-ink-muted hover:text-ink hover:bg-surface-sunken rounded-lg transition-all">Statystyki</a>
          <a href="/o-nas" class="px-3 py-1.5 text-sm text-ink-muted hover:text-ink hover:bg-surface-sunken rounded-lg transition-all">O nas</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-border bg-surface-raised mt-24">
      <div class="max-w-5xl mx-auto px-5 py-8 flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-baseline gap-0.5">
          <span class="font-bold text-ink">nie</span><span class="font-bold text-brand-500">jedzie</span><span class="text-sm text-ink-faint">.pl</span>
        </div>
        <div class="flex gap-6 text-sm text-ink-faint">
          <a href="/jak-sprawdzic-opoznienie" class="hover:text-ink transition-colors">Poradnik</a>
          <a href="/reklamacja-pkp" class="hover:text-ink transition-colors">Reklamacja</a>
          <a href="/odszkodowanie-za-opoznienie" class="hover:text-ink transition-colors">Odszkodowanie</a>
          <a href="/o-nas" class="hover:text-ink transition-colors">O nas</a>
        </div>
        <p class="text-xs text-ink-faint">
          Dane: PKP PLK &middot; Nie jesteśmy powiązani z PKP
        </p>
      </div>
    </footer>
  </body>
</html>
